//@version=6
indicator(title='AIO Sniper [SMC HUD]', shorttitle="AIO Sniper", overlay=true, max_bars_back=500, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// ── SMC Settings ──────────────────────────────────────────────────────────────
smc_group = "Smart Money Concepts"
smc_swing_length = input.int(50, "Swing Length", minval=1, group=smc_group)
smc_internal_length = input.int(5, "Internal Structure Length", minval=1, group=smc_group)
smc_eq_length = input.int(3, "Equal Highs/Lows Length", minval=1, group=smc_group)
smc_show_swing = input.bool(true, "Show Swing Structure", group=smc_group)
smc_show_internals = input.bool(true, "Show Internal Structure", group=smc_group)
smc_show_ob = input.bool(true, "Show Order Blocks", group=smc_group)
smc_show_fvg = input.bool(true, "Show Fair Value Gaps", group=smc_group)
smc_show_eq = input.bool(true, "Show Equal H/L", group=smc_group)
smc_show_hl = input.bool(true, "Show Strong/Weak H/L", group=smc_group)
smc_ob_size = input.int(5, "Max OBs Displayed", minval=1, maxval=20, group=smc_group)
smc_style = input.string("Colored", "Style", options=["Colored", "Monochrome"], group=smc_group)
smc_mode = input.string("Present", "Display Mode", options=["Present", "Historical"], group=smc_group)
smc_sw_bull_color = input.color(#089981, "Swing Bullish", group=smc_group, inline='swc')
smc_sw_bear_color = input.color(#f23645, "Swing Bearish", group=smc_group, inline='swc')
smc_int_bull_color = input.color(#089981, "Internal Bullish", group=smc_group, inline='intc')
smc_int_bear_color = input.color(#f23645, "Internal Bearish", group=smc_group, inline='intc')

// ── Premium/Discount Zones ────────────────────────────────────────────────────
pd_group = "Premium/Discount Zones"
show_pd_zones = input.bool(true, "Show Premium/Discount Zones", group=pd_group)
pd_premium_color = input.color(color.new(color.red, 92), "Premium Zone Color", group=pd_group, inline='pd')
pd_discount_color = input.color(color.new(color.green, 92), "Discount Zone Color", group=pd_group, inline='pd')
pd_midline_color = input.color(color.new(color.gray, 60), "50% Midline Color", group=pd_group, inline='pd2')
pd_boundary_color = input.color(color.new(color.gray, 70), "0%/100% Line Color", group=pd_group, inline='pd2')
pd_zone_filter = input.bool(true, "Filter OB/FVG by Zone", group=pd_group)

// ── Kill Zones (HSI HKT) ─────────────────────────────────────────────────────
kz_group = "Kill Zones (HSI)"
show_kz = input.bool(true, "Show Kill Zones", group=kz_group)
kz1_time = input.session("0930-1130", "Morning KZ (09:30-11:30)", group=kz_group, inline='kz1')
kz1_color = input.color(color.new(color.green, 92), "", group=kz_group, inline='kz1')
kz1_on = input.bool(true, "", group=kz_group, inline='kz1')
gt1_time = input.session("1130-1330", "Lunch Garbage (11:30-13:30)", group=kz_group, inline='gt1')
gt1_color = input.color(color.new(color.gray, 92), "", group=kz_group, inline='gt1')
gt1_on = input.bool(true, "", group=kz_group, inline='gt1')
kz2_time = input.session("1330-1500", "Afternoon KZ (13:30-15:00)", group=kz_group, inline='kz2')
kz2_color = input.color(color.new(color.yellow, 92), "", group=kz_group, inline='kz2')
kz2_on = input.bool(true, "", group=kz_group, inline='kz2')
gt2_time = input.session("1500-1600", "Close Garbage (15:00-16:00)", group=kz_group, inline='gt2')
gt2_color = input.color(color.new(color.red, 92), "", group=kz_group, inline='gt2')
gt2_on = input.bool(true, "", group=kz_group, inline='gt2')
kz_timezone = input.string("Asia/Hong_Kong", "Timezone", options=["Asia/Hong_Kong", "America/New_York", "Europe/London", "Asia/Tokyo", "Etc/UTC"], group=kz_group)

// ── Liquidity Targets ─────────────────────────────────────────────────────────
liq_group = "Liquidity Targets"
show_pdh_pdl = input.bool(true, "Show PDH/PDL", group=liq_group, inline='liq1')
pdh_pdl_color = input.color(color.new(color.orange, 40), "PDH/PDL Color", group=liq_group, inline='liq1')
show_session_hl = input.bool(true, "Show Session H/L", group=liq_group, inline='liq2')
session_hl_color = input.color(color.new(color.blue, 40), "Session H/L Color", group=liq_group, inline='liq2')

// ── R:R Dashboard ─────────────────────────────────────────────────────────────
rr_group = "R:R Dashboard"
show_rr_dashboard = input.bool(true, "Show R:R Dashboard", group=rr_group)
rr_sl_mode = input.string("Aggressive (OB+Buffer)", "SL Mode", options=["Aggressive (OB+Buffer)", "Conservative (Swing+Buffer)"], group=rr_group)
rr_buffer = input.float(20.0, "SL Buffer (points)", minval=0, group=rr_group, inline='rrbuf')
rr_smart_toggle_dist = input.float(30.0, "Smart Toggle Distance (pts)", minval=0, group=rr_group, inline='rrbuf')
rr_account_size = input.float(100000.0, "Account Size", minval=0, group=rr_group, inline='rracc')
rr_risk_pct = input.float(1.0, "Risk %", minval=0.1, maxval=10, group=rr_group, inline='rracc')
rr_min_rr = input.float(2.0, "Minimum R:R", minval=0.5, group=rr_group)
rr_dash_pos = input.string("bottom_right", "Dashboard Position", options=["top_left", "top_right", "bottom_left", "bottom_right"], group=rr_group)

// ── Signals ───────────────────────────────────────────────────────────────────
sig_group = "Signals"
show_signals = input.bool(true, "Show Entry Signals", group=sig_group)

// ── Trading Plays ─────────────────────────────────────────────────────────────
play_group = "Trading Plays"
show_play1 = input.bool(true, "Play 1: 回調狙擊 (Continuation)", group=play_group)
show_play2 = input.bool(true, "Play 2: 流動性掃蕩 (Liq Sweep)", group=play_group)
show_play3 = input.bool(true, "Play 3: 午後反轉 (Trend Shift)", group=play_group)
play_sweep_window = input.int(5, "Sweep CHoCH Window (bars)", minval=1, maxval=20, group=play_group)

// ══════════════════════════════════════════════════════════════════════════════
// SMC CORE
// ══════════════════════════════════════════════════════════════════════════════

// ── Constants ─────────────────────────────────────────────────────────────────
SMC_BULLISH = +1
SMC_BEARISH = -1
SMC_BULLISH_LEG = 1
SMC_BEARISH_LEG = 0
SMC_GREEN = #089981
SMC_RED = #F23645
SMC_MONO_BULL = #b2b5be
SMC_MONO_BEAR = #5d606b

// ── Types ─────────────────────────────────────────────────────────────────────
type smc_pivot
    float currentLevel
    float lastLevel
    bool crossed
    int barTime = time
    int barIndex = bar_index

type smc_trend
    int bias

type smc_orderBlock
    float barHigh
    float barLow
    int barTime
    int bias

type smc_fairValueGap
    float top
    float bottom
    int bias
    box topBox
    box bottomBox

type smc_trailingExtremes
    float top
    float bottom
    int barTime
    int barIndex
    int lastTopTime
    int lastBottomTime

type smc_equalDisplay
    line l_ine = na
    label l_abel = na

type smc_alerts
    bool swingBullishBOS = false
    bool swingBearishBOS = false
    bool swingBullishCHoCH = false
    bool swingBearishCHoCH = false
    bool internalBullishBOS = false
    bool internalBearishBOS = false
    bool internalBullishCHoCH = false
    bool internalBearishCHoCH = false
    bool equalHighs = false
    bool equalLows = false

// ── Variables ─────────────────────────────────────────────────────────────────
var smc_pivot smc_swingHigh = smc_pivot.new(na, na, false)
var smc_pivot smc_swingLow = smc_pivot.new(na, na, false)
var smc_pivot smc_internalHigh = smc_pivot.new(na, na, false)
var smc_pivot smc_internalLow = smc_pivot.new(na, na, false)
var smc_pivot smc_equalHigh = smc_pivot.new(na, na, false)
var smc_pivot smc_equalLow = smc_pivot.new(na, na, false)
var smc_trend smc_swingTrend = smc_trend.new(0)
var smc_trend smc_internalTrend = smc_trend.new(0)
var smc_equalDisplay smc_eqHighDisplay = smc_equalDisplay.new()
var smc_equalDisplay smc_eqLowDisplay = smc_equalDisplay.new()
var array<smc_fairValueGap> smc_fvgs = array.new<smc_fairValueGap>()
var array<smc_orderBlock> smc_swingOBs = array.new<smc_orderBlock>()
var array<smc_orderBlock> smc_internalOBs = array.new<smc_orderBlock>()
var array<box> smc_swingOBBoxes = array.new<box>()
var array<box> smc_internalOBBoxes = array.new<box>()
var smc_trailingExtremes smc_trailing = smc_trailingExtremes.new()
var smc_alerts smc_currentAlerts = smc_alerts.new()
smc_currentAlerts := smc_alerts.new()

// ── Colors ────────────────────────────────────────────────────────────────────
smc_swingBullColor = smc_style == "Monochrome" ? SMC_MONO_BULL : smc_sw_bull_color
smc_swingBearColor = smc_style == "Monochrome" ? SMC_MONO_BEAR : smc_sw_bear_color
smc_intBullColor = smc_style == "Monochrome" ? SMC_MONO_BULL : smc_int_bull_color
smc_intBearColor = smc_style == "Monochrome" ? SMC_MONO_BEAR : smc_int_bear_color

// ── Volatility ────────────────────────────────────────────────────────────────
smc_atr = ta.atr(200)
smc_volMeasure = bar_index > 0 ? ta.cum(ta.tr) / bar_index : ta.tr
smc_highVolBar = (high - low) >= (2 * smc_volMeasure)
smc_parsedHigh = smc_highVolBar ? low : high
smc_parsedLow = smc_highVolBar ? high : low
smc_bearMitSrc = close
smc_bullMitSrc = close

// ── Functions ─────────────────────────────────────────────────────────────────
smc_leg(int size) =>
    var leg = 0
    newLegHigh = high[size] > ta.highest(size)
    newLegLow = low[size] < ta.lowest(size)
    if newLegHigh
        leg := SMC_BEARISH_LEG
    else if newLegLow
        leg := SMC_BULLISH_LEG
    leg

smc_drawLabel(int labelTime, float labelPrice, string tag, color labelColor, string labelStyle) =>
    var label l_abel = na
    if smc_mode == "Present"
        l_abel.delete()
    l_abel := label.new(chart.point.from_time(labelTime, labelPrice), tag, xloc.bar_time, color=color(na), textcolor=labelColor, style=labelStyle, size=size.small)

smc_drawStructure(smc_pivot p_ivot, string tag, color structureColor, string lineStyle, string labelStyle, string labelSize) =>
    var line l_ine = line.new(na, na, na, na, xloc=xloc.bar_time)
    var label l_abel = label.new(na, na)
    if smc_mode == "Present"
        l_ine.delete()
        l_abel.delete()
    l_ine := line.new(chart.point.from_time(p_ivot.barTime, p_ivot.currentLevel), chart.point.from_time(time, p_ivot.currentLevel), xloc.bar_time, color=structureColor, style=lineStyle)
    l_abel := label.new(chart.point.from_index(math.round(0.5 * (p_ivot.barIndex + bar_index)), p_ivot.currentLevel), tag, xloc.bar_index, color=color(na), textcolor=structureColor, style=labelStyle, size=labelSize)

smc_drawEqualHL(smc_pivot p_ivot, float level, int size, bool equalHigh) =>
    smc_equalDisplay e_Display = equalHigh ? smc_eqHighDisplay : smc_eqLowDisplay
    string tag = equalHigh ? 'EQH' : 'EQL'
    color eqColor = equalHigh ? smc_swingBearColor : smc_swingBullColor
    string lStyle = equalHigh ? label.style_label_down : label.style_label_up
    if smc_mode == "Present"
        line.delete(e_Display.l_ine)
        label.delete(e_Display.l_abel)
    e_Display.l_ine := line.new(chart.point.from_time(p_ivot.barTime, p_ivot.currentLevel), chart.point.from_time(time[size], level), xloc.bar_time, color=eqColor, style=line.style_dotted)
    e_Display.l_abel := label.new(chart.point.from_index(math.round(0.5 * (p_ivot.barIndex + bar_index - size)), level), tag, xloc.bar_index, color=color(na), textcolor=eqColor, style=lStyle, size=size.tiny)

smc_storeOB(smc_pivot p_ivot, bool internal, int bias) =>
    int ob_lookback = bar_index - p_ivot.barIndex
    float ob_high = ta.highest(high, ob_lookback)
    float ob_low = ta.lowest(low, ob_lookback)
    if (not internal and smc_show_ob) or (internal and smc_show_ob)
        float ph = bias == SMC_BEARISH ? smc_parsedHigh : smc_parsedLow
        float best = bias == SMC_BEARISH ? ob_high : ob_low
        smc_orderBlock ob = smc_orderBlock.new(high, low, time, bias)
        array<smc_orderBlock> obs = internal ? smc_internalOBs : smc_swingOBs
        if obs.size() >= 50
            obs.pop()
        obs.unshift(ob)

bool smc_ob_bull_mitigated = false
bool smc_ob_bear_mitigated = false

smc_deleteOBs(bool internal = false) =>
    array<smc_orderBlock> obs = internal ? smc_internalOBs : smc_swingOBs
    bool _bear_mit = false
    bool _bull_mit = false
    for [index, eachOB] in obs
        bool crossed = false
        if (smc_bearMitSrc > eachOB.barHigh) and (eachOB.bias == SMC_BEARISH)
            crossed := true
            _bear_mit := true
        else if (smc_bullMitSrc < eachOB.barLow) and (eachOB.bias == SMC_BULLISH)
            crossed := true
            _bull_mit := true
        if crossed
            obs.remove(index)
    [_bear_mit, _bull_mit]

smc_drawOBs(bool internal, float pd_mid) =>
    array<smc_orderBlock> obs = internal ? smc_internalOBs : smc_swingOBs
    array<box> b_oxes = internal ? smc_internalOBBoxes : smc_swingOBBoxes
    maxOBs = smc_ob_size
    if obs.size() > 0
        parsed = obs.slice(0, math.min(maxOBs, obs.size()))
        for [index, eachOB] in parsed
            // Zone filter: bullish OB must be in discount (below mid), bearish OB must be in premium (above mid)
            if pd_zone_filter
                if eachOB.bias == SMC_BULLISH and eachOB.barHigh >= pd_mid
                    continue
                if eachOB.bias == SMC_BEARISH and eachOB.barLow <= pd_mid
                    continue
            obColor = internal ? (eachOB.bias == SMC_BEARISH ? color.new(#f77c80, 80) : color.new(#3179f5, 80)) : (eachOB.bias == SMC_BEARISH ? color.new(#b22833, 80) : color.new(#1848cc, 80))
            if index < b_oxes.size()
                box b = b_oxes.get(index)
                b.set_top_left_point(chart.point.from_time(eachOB.barTime, eachOB.barHigh))
                b.set_bottom_right_point(chart.point.from_time(last_bar_time, eachOB.barLow))
                b.set_bgcolor(obColor)
                b.set_border_color(eachOB.bias == SMC_BULLISH ? color.new(#089981, 40) : color.new(#f23645, 40))
                b.set_border_width(1)
                string obTag = (eachOB.bias == SMC_BULLISH ? "Bull OB " : "Bear OB ") + str.tostring(eachOB.barLow, format.mintick) + "-" + str.tostring(eachOB.barHigh, format.mintick)
                b.set_text(obTag)
                b.set_text_color(eachOB.bias == SMC_BULLISH ? color.new(#089981, 20) : color.new(#f23645, 20))
                b.set_text_size(size.tiny)

smc_deleteFVGs() =>
    for [index, eachFVG] in smc_fvgs
        if (low < eachFVG.bottom and eachFVG.bias == SMC_BULLISH) or (high > eachFVG.top and eachFVG.bias == SMC_BEARISH)
            eachFVG.topBox.delete()
            eachFVG.bottomBox.delete()
            smc_fvgs.remove(index)

smc_drawFVGs(float pd_mid) =>
    bullishFVG = low > high[2] and close > high[2]
    bearishFVG = high < low[2] and close < low[2]
    fvgBullColor = smc_style == "Monochrome" ? color.new(SMC_MONO_BULL, 70) : color.new(#00ff68, 70)
    fvgBearColor = smc_style == "Monochrome" ? color.new(SMC_MONO_BEAR, 70) : color.new(#ff0008, 70)
    if bullishFVG
        // Zone filter: bullish FVG must be in discount zone
        if not pd_zone_filter or high[2] < pd_mid
            float gapSize = low - high[2]
            smc_fvgs.unshift(smc_fairValueGap.new(low, high[2], SMC_BULLISH, box.new(bar_index - 1, low, bar_index, math.avg(low, high[2]), border_color=fvgBullColor, bgcolor=fvgBullColor, text="FVG +" + str.tostring(gapSize, format.mintick), text_color=color.new(#089981, 20), text_size=size.tiny), box.new(bar_index - 1, math.avg(low, high[2]), bar_index, high[2], border_color=fvgBullColor, bgcolor=fvgBullColor)))
    if bearishFVG
        // Zone filter: bearish FVG must be in premium zone
        if not pd_zone_filter or low[2] > pd_mid
            float gapSize = low[2] - high
            smc_fvgs.unshift(smc_fairValueGap.new(high, low[2], SMC_BEARISH, box.new(bar_index - 1, high, bar_index, math.avg(high, low[2]), border_color=fvgBearColor, bgcolor=fvgBearColor, text="FVG -" + str.tostring(gapSize, format.mintick), text_color=color.new(#f23645, 20), text_size=size.tiny), box.new(bar_index - 1, math.avg(high, low[2]), bar_index, low[2], border_color=fvgBearColor, bgcolor=fvgBearColor)))

smc_getStructure(int size, bool equalHL = false, bool internal = false) =>
    currentLeg = smc_leg(size)
    newPivot = ta.change(currentLeg) != 0
    pivotLow = ta.change(currentLeg) == +1
    pivotHigh = ta.change(currentLeg) == -1

    if newPivot
        if pivotLow
            smc_pivot p_ivot = equalHL ? smc_equalLow : internal ? smc_internalLow : smc_swingLow
            if equalHL and math.abs(p_ivot.currentLevel - low[size]) < 0.1 * smc_atr
                smc_drawEqualHL(p_ivot, low[size], size, false)
                smc_currentAlerts.equalLows := true
            p_ivot.lastLevel := p_ivot.currentLevel
            p_ivot.currentLevel := low[size]
            p_ivot.crossed := false
            p_ivot.barTime := time[size]
            p_ivot.barIndex := bar_index[size]
            if not equalHL and not internal
                smc_trailing.bottom := p_ivot.currentLevel
                smc_trailing.barTime := p_ivot.barTime
                smc_trailing.barIndex := p_ivot.barIndex
                smc_trailing.lastBottomTime := p_ivot.barTime
        else
            smc_pivot p_ivot = equalHL ? smc_equalHigh : internal ? smc_internalHigh : smc_swingHigh
            if equalHL and math.abs(p_ivot.currentLevel - high[size]) < 0.1 * smc_atr
                smc_drawEqualHL(p_ivot, high[size], size, true)
                smc_currentAlerts.equalHighs := true
            p_ivot.lastLevel := p_ivot.currentLevel
            p_ivot.currentLevel := high[size]
            p_ivot.crossed := false
            p_ivot.barTime := time[size]
            p_ivot.barIndex := bar_index[size]
            if not equalHL and not internal
                smc_trailing.top := p_ivot.currentLevel
                smc_trailing.barTime := p_ivot.barTime
                smc_trailing.barIndex := p_ivot.barIndex
                smc_trailing.lastTopTime := p_ivot.barTime

smc_displayStructure(bool internal = false) =>
    smc_pivot p_ivot = internal ? smc_internalHigh : smc_swingHigh
    smc_trend t_rend = internal ? smc_internalTrend : smc_swingTrend
    lineStyle = internal ? line.style_dashed : line.style_solid
    labelSize = internal ? size.tiny : size.small
    bullColor = internal ? smc_intBullColor : smc_swingBullColor

    bool bullCross = ta.crossover(close, p_ivot.currentLevel) and not p_ivot.crossed
    smc_storeOB(p_ivot, internal, SMC_BULLISH)
    if bullCross
        string tag = t_rend.bias == SMC_BEARISH ? "CHoCH" : "BOS"
        if internal
            smc_currentAlerts.internalBullishCHoCH := tag == "CHoCH"
            smc_currentAlerts.internalBullishBOS := tag == "BOS"
        else
            smc_currentAlerts.swingBullishCHoCH := tag == "CHoCH"
            smc_currentAlerts.swingBullishBOS := tag == "BOS"
        p_ivot.crossed := true
        t_rend.bias := SMC_BULLISH
        showCond = internal ? smc_show_internals : smc_show_swing
        if showCond
            smc_drawStructure(p_ivot, tag, bullColor, lineStyle, label.style_label_down, labelSize)

    p_ivot := internal ? smc_internalLow : smc_swingLow
    bearColor = internal ? smc_intBearColor : smc_swingBearColor

    bool bearCross = ta.crossunder(close, p_ivot.currentLevel) and not p_ivot.crossed
    smc_storeOB(p_ivot, internal, SMC_BEARISH)
    if bearCross
        string tag = t_rend.bias == SMC_BULLISH ? "CHoCH" : "BOS"
        if internal
            smc_currentAlerts.internalBearishCHoCH := tag == "CHoCH"
            smc_currentAlerts.internalBearishBOS := tag == "BOS"
        else
            smc_currentAlerts.swingBearishCHoCH := tag == "CHoCH"
            smc_currentAlerts.swingBearishBOS := tag == "BOS"
        p_ivot.crossed := true
        t_rend.bias := SMC_BEARISH
        showCond = internal ? smc_show_internals : smc_show_swing
        if showCond
            smc_drawStructure(p_ivot, tag, bearColor, lineStyle, label.style_label_up, labelSize)

// ══════════════════════════════════════════════════════════════════════════════
// SMC EXECUTION
// ══════════════════════════════════════════════════════════════════════════════

bool smc_long = false
bool smc_short = false
bool smc_conf_long = false
bool smc_conf_short = false
bool fv_ob_conf_long = false
bool fv_ob_conf_short = false

// Init OB boxes
if barstate.isfirst
    if smc_show_ob
        for i = 1 to smc_ob_size
            smc_swingOBBoxes.push(box.new(na, na, na, na, extend=extend.right))
            smc_internalOBBoxes.push(box.new(na, na, na, na, extend=extend.right))

// Update trailing
if smc_show_hl
    smc_trailing.top := math.max(high, smc_trailing.top)
    smc_trailing.lastTopTime := smc_trailing.top == high ? time : smc_trailing.lastTopTime
    smc_trailing.bottom := math.min(low, smc_trailing.bottom)
    smc_trailing.lastBottomTime := smc_trailing.bottom == low ? time : smc_trailing.lastBottomTime

// Structure detection
smc_getStructure(smc_swing_length, false, false)
smc_getStructure(smc_internal_length, false, true)
if smc_show_eq
    smc_getStructure(smc_eq_length, true)

// Display structure
if smc_show_internals or smc_show_ob
    smc_displayStructure(true)
if smc_show_swing or smc_show_hl
    smc_displayStructure()

// Premium/Discount midpoint (computed every bar for zone filtering)
float pd_mid = na(smc_swingHigh.currentLevel) or na(smc_swingLow.currentLevel) ? na : math.avg(smc_swingHigh.currentLevel, smc_swingLow.currentLevel)

// Order blocks
if smc_show_ob
    [_bm1, _bl1] = smc_deleteOBs(true)
    [_bm2, _bl2] = smc_deleteOBs(false)
    if _bm1 or _bm2
        smc_ob_bear_mitigated := true
    if _bl1 or _bl2
        smc_ob_bull_mitigated := true

// FVGs
if smc_show_fvg
    smc_deleteFVGs()
    smc_drawFVGs(pd_mid)

// Draw OBs on last bar
if barstate.islastconfirmedhistory or barstate.islast
    if smc_show_ob
        smc_drawOBs(true, pd_mid)
        smc_drawOBs(false, pd_mid)

// FVG-OB Confluence Detection
fv_ob_conf_long := false
fv_ob_conf_short := false
if smc_show_ob and smc_show_fvg
    for eachFVG in smc_fvgs
        for eachOB in smc_swingOBs
            if eachOB.barHigh > eachFVG.bottom and eachOB.barLow < eachFVG.top
                if eachFVG.bias == SMC_BULLISH and eachOB.bias == SMC_BULLISH
                    fv_ob_conf_long := true
                else if eachFVG.bias == SMC_BEARISH and eachOB.bias == SMC_BEARISH
                    fv_ob_conf_short := true

// Draw Strong/Weak H/L
if smc_show_hl and (barstate.islastconfirmedhistory or barstate.islast)
    var line smc_topLine = line.new(na, na, na, na, color=smc_swingBearColor)
    var line smc_botLine = line.new(na, na, na, na, color=smc_swingBullColor)
    var label smc_topLabel = label.new(na, na, color=color(na), textcolor=smc_swingBearColor, style=label.style_label_down, size=size.tiny)
    var label smc_botLabel = label.new(na, na, color=color(na), textcolor=smc_swingBullColor, style=label.style_label_up, size=size.tiny)
    int hl_right = bar_index + 20
    smc_topLine.set_first_point(chart.point.from_index(bar_index - 50, smc_trailing.top))
    smc_topLine.set_second_point(chart.point.from_index(hl_right, smc_trailing.top))
    smc_topLabel.set_point(chart.point.from_index(hl_right, smc_trailing.top))
    smc_topLabel.set_text(smc_swingTrend.bias == SMC_BEARISH ? 'Strong High' : 'Weak High')
    smc_botLine.set_first_point(chart.point.from_index(bar_index - 50, smc_trailing.bottom))
    smc_botLine.set_second_point(chart.point.from_index(hl_right, smc_trailing.bottom))
    smc_botLabel.set_point(chart.point.from_index(hl_right, smc_trailing.bottom))
    smc_botLabel.set_text(smc_swingTrend.bias == SMC_BULLISH ? 'Strong Low' : 'Weak Low')

// SMC signals
var int smc_prev_bias = 0
smc_trend_changed = smc_swingTrend.bias != smc_prev_bias
smc_prev_bias := smc_swingTrend.bias
smc_long := smc_swingTrend.bias == SMC_BULLISH and smc_trend_changed
smc_short := smc_swingTrend.bias == SMC_BEARISH and smc_trend_changed
smc_conf_long := smc_swingTrend.bias == SMC_BULLISH
smc_conf_short := smc_swingTrend.bias == SMC_BEARISH

// ══════════════════════════════════════════════════════════════════════════════
// PREMIUM / DISCOUNT ZONES
// ══════════════════════════════════════════════════════════════════════════════

if show_pd_zones and not na(pd_mid) and (barstate.islastconfirmedhistory or barstate.islast)
    float swHigh = smc_swingHigh.currentLevel
    float swLow = smc_swingLow.currentLevel
    int rightEdge = bar_index + 20
    int leftEdge = bar_index - 50
    var box pd_premiumBox = box.new(na, na, na, na, border_color=na, bgcolor=pd_premium_color)
    var box pd_discountBox = box.new(na, na, na, na, border_color=na, bgcolor=pd_discount_color)
    var line pd_midLine = line.new(na, na, na, na, color=pd_midline_color, style=line.style_dashed)
    var line pd_topLine = line.new(na, na, na, na, color=pd_boundary_color, style=line.style_dotted)
    var line pd_botLine = line.new(na, na, na, na, color=pd_boundary_color, style=line.style_dotted)
    var label pd_midLabel = label.new(na, na, color=color(na), textcolor=pd_midline_color, style=label.style_label_left, size=size.tiny)
    var label pd_topLabel = label.new(na, na, color=color(na), textcolor=pd_boundary_color, style=label.style_label_left, size=size.tiny)
    var label pd_botLabel = label.new(na, na, color=color(na), textcolor=pd_boundary_color, style=label.style_label_left, size=size.tiny)

    // Premium box: from mid to swing high
    pd_premiumBox.set_top_left_point(chart.point.from_index(leftEdge, swHigh))
    pd_premiumBox.set_bottom_right_point(chart.point.from_index(rightEdge, pd_mid))
    pd_premiumBox.set_bgcolor(pd_premium_color)

    // Discount box: from mid to swing low
    pd_discountBox.set_top_left_point(chart.point.from_index(leftEdge, pd_mid))
    pd_discountBox.set_bottom_right_point(chart.point.from_index(rightEdge, swLow))
    pd_discountBox.set_bgcolor(pd_discount_color)

    // Lines
    pd_midLine.set_first_point(chart.point.from_index(leftEdge, pd_mid))
    pd_midLine.set_second_point(chart.point.from_index(rightEdge, pd_mid))
    pd_topLine.set_first_point(chart.point.from_index(leftEdge, swHigh))
    pd_topLine.set_second_point(chart.point.from_index(rightEdge, swHigh))
    pd_botLine.set_first_point(chart.point.from_index(leftEdge, swLow))
    pd_botLine.set_second_point(chart.point.from_index(rightEdge, swLow))

    // Labels
    pd_midLabel.set_point(chart.point.from_index(rightEdge, pd_mid))
    pd_midLabel.set_text("50%")
    pd_topLabel.set_point(chart.point.from_index(rightEdge, swHigh))
    pd_topLabel.set_text("100% Premium")
    pd_botLabel.set_point(chart.point.from_index(rightEdge, swLow))
    pd_botLabel.set_text("0% Discount")

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY TARGETS: PDH/PDL
// ══════════════════════════════════════════════════════════════════════════════

var float prev_day_high = na
var float prev_day_low = na
var float current_day_high = na
var float current_day_low = na

is_new_day = ta.change(time("D")) != 0
if is_new_day
    prev_day_high := nz(current_day_high, high)
    prev_day_low := nz(current_day_low, low)
    current_day_high := high
    current_day_low := low
else
    current_day_high := math.max(nz(current_day_high, high), high)
    current_day_low := math.min(nz(current_day_low, low), low)

if show_pdh_pdl and not na(prev_day_high) and (barstate.islastconfirmedhistory or barstate.islast)
    int pdh_left = bar_index - 50
    int pdh_right = bar_index + 20
    var line pdh_line = line.new(na, na, na, na, color=pdh_pdl_color, style=line.style_dashed)
    var line pdl_line = line.new(na, na, na, na, color=pdh_pdl_color, style=line.style_dashed)
    var label pdh_label = label.new(na, na, color=color(na), textcolor=pdh_pdl_color, style=label.style_label_left, size=size.tiny)
    var label pdl_label = label.new(na, na, color=color(na), textcolor=pdh_pdl_color, style=label.style_label_left, size=size.tiny)

    pdh_line.set_first_point(chart.point.from_index(pdh_left, prev_day_high))
    pdh_line.set_second_point(chart.point.from_index(pdh_right, prev_day_high))
    pdl_line.set_first_point(chart.point.from_index(pdh_left, prev_day_low))
    pdl_line.set_second_point(chart.point.from_index(pdh_right, prev_day_low))
    pdh_label.set_point(chart.point.from_index(pdh_right, prev_day_high))
    pdh_label.set_text("PDH")
    pdl_label.set_point(chart.point.from_index(pdh_right, prev_day_low))
    pdl_label.set_text("PDL")

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY TARGETS: SESSION H/L
// ══════════════════════════════════════════════════════════════════════════════

hsi_session = time(timeframe.period, "0930-1600", kz_timezone)
var float sess_high = na
var float sess_low = na

bool new_session = not na(hsi_session) and na(hsi_session[1])
if new_session
    sess_high := high
    sess_low := low
else if not na(hsi_session)
    sess_high := math.max(nz(sess_high, high), high)
    sess_low := math.min(nz(sess_low, low), low)

if show_session_hl and not na(sess_high) and not na(hsi_session) and (barstate.islastconfirmedhistory or barstate.islast)
    int sess_left = bar_index - 20
    int sess_right = bar_index + 20
    var line sess_h_line = line.new(na, na, na, na, color=session_hl_color, style=line.style_solid)
    var line sess_l_line = line.new(na, na, na, na, color=session_hl_color, style=line.style_solid)
    var label sess_h_label = label.new(na, na, color=color(na), textcolor=session_hl_color, style=label.style_label_left, size=size.tiny)
    var label sess_l_label = label.new(na, na, color=color(na), textcolor=session_hl_color, style=label.style_label_left, size=size.tiny)

    sess_h_line.set_first_point(chart.point.from_index(sess_left, sess_high))
    sess_h_line.set_second_point(chart.point.from_index(sess_right, sess_high))
    sess_l_line.set_first_point(chart.point.from_index(sess_left, sess_low))
    sess_l_line.set_second_point(chart.point.from_index(sess_right, sess_low))
    sess_h_label.set_point(chart.point.from_index(sess_right, sess_high))
    sess_h_label.set_text("Session H")
    sess_l_label.set_point(chart.point.from_index(sess_right, sess_low))
    sess_l_label.set_text("Session L")

// ══════════════════════════════════════════════════════════════════════════════
// KILL ZONES & GARBAGE TIME
// ══════════════════════════════════════════════════════════════════════════════

in_kz1 = show_kz and kz1_on and not na(time(timeframe.period, kz1_time, kz_timezone))
in_gt1 = show_kz and gt1_on and not na(time(timeframe.period, gt1_time, kz_timezone))
in_kz2 = show_kz and kz2_on and not na(time(timeframe.period, kz2_time, kz_timezone))
in_gt2 = show_kz and gt2_on and not na(time(timeframe.period, gt2_time, kz_timezone))
bgcolor(in_kz1 ? kz1_color : in_gt1 ? gt1_color : in_kz2 ? kz2_color : in_gt2 ? gt2_color : na, title="Kill Zones")

// ══════════════════════════════════════════════════════════════════════════════
// SIGNALS: Discount + Bullish CHoCH = Long, Premium + Bearish CHoCH = Short
// ══════════════════════════════════════════════════════════════════════════════

bool in_discount = not na(pd_mid) and close < pd_mid
bool in_premium = not na(pd_mid) and close > pd_mid

bool sniper_long = in_discount and smc_currentAlerts.swingBullishCHoCH
bool sniper_short = in_premium and smc_currentAlerts.swingBearishCHoCH

plotshape(show_signals and sniper_long ? low : na, title='Sniper Long', text='LONG', textcolor=color.white, style=shape.labelup, size=size.small, location=location.belowbar, color=color.new(color.green, 0))
plotshape(show_signals and sniper_short ? high : na, title='Sniper Short', text='SHORT', textcolor=color.white, style=shape.labeldown, size=size.small, location=location.abovebar, color=color.new(color.red, 0))

// ══════════════════════════════════════════════════════════════════════════════
// TRADING PLAYS
// ══════════════════════════════════════════════════════════════════════════════

// ── State Tracking ────────────────────────────────────────────────────────────
var int morning_trend = 0
var bool swept_pdl = false
var bool swept_pdh = false
var int sweep_bar = 0
var float sweep_low = na
var float sweep_high = na

// Track morning trend before 13:00 HKT
in_morning = not na(time(timeframe.period, "0930-1300", kz_timezone))
if in_morning
    morning_trend := smc_swingTrend.bias

// ── Liquidity Sweep Detection ─────────────────────────────────────────────────
sweep_below_pdl = not na(prev_day_low) and low < prev_day_low and close > prev_day_low
sweep_above_pdh = not na(prev_day_high) and high > prev_day_high and close < prev_day_high

if sweep_below_pdl
    swept_pdl := true
    sweep_bar := bar_index
    sweep_low := low
if sweep_above_pdh
    swept_pdh := true
    sweep_bar := bar_index
    sweep_high := high

// Reset sweep flags after window expires
if swept_pdl and bar_index - sweep_bar > play_sweep_window
    swept_pdl := false
if swept_pdh and bar_index - sweep_bar > play_sweep_window
    swept_pdh := false

// ── Play 1: 順勢回調狙擊 (Trend Continuation) ────────────────────────────────
// Long: Bullish trend + price in discount + touches bullish OB
// Short: Bearish trend + price in premium + touches bearish OB
bool price_in_bull_ob = false
float bull_ob_low = na
float bull_ob_high = na
bool price_in_bear_ob = false
float bear_ob_low = na
float bear_ob_high = na

if smc_swingOBs.size() > 0
    for eachOB in smc_swingOBs
        if eachOB.bias == SMC_BULLISH and not na(pd_mid) and eachOB.barHigh < pd_mid
            if low <= eachOB.barHigh and close >= eachOB.barLow
                price_in_bull_ob := true
                bull_ob_low := nz(bull_ob_low, eachOB.barLow)
                bull_ob_high := eachOB.barHigh
        if eachOB.bias == SMC_BEARISH and not na(pd_mid) and eachOB.barLow > pd_mid
            if high >= eachOB.barLow and close <= eachOB.barHigh
                price_in_bear_ob := true
                bear_ob_high := nz(bear_ob_high, eachOB.barHigh)
                bear_ob_low := eachOB.barLow

bool play1_long = show_play1 and smc_swingTrend.bias == SMC_BULLISH and in_discount and price_in_bull_ob
bool play1_short = show_play1 and smc_swingTrend.bias == SMC_BEARISH and in_premium and price_in_bear_ob

// ── Play 2: 早市流動性掃蕩 (Morning Liquidity Sweep) ──────────────────────────
// Long: Sweep below PDL + reclaim + Bullish CHoCH in morning KZ
// Short: Sweep above PDH + reject + Bearish CHoCH in morning KZ
bool play2_long = show_play2 and swept_pdl and (smc_currentAlerts.swingBullishCHoCH or smc_currentAlerts.internalBullishCHoCH) and in_kz1
bool play2_short = show_play2 and swept_pdh and (smc_currentAlerts.swingBearishCHoCH or smc_currentAlerts.internalBearishCHoCH) and in_kz1

// ── Play 3: 午後結構破壞跟隨 (Afternoon Trend Shift) ──────────────────────────
// Short: Morning was bullish + afternoon Bearish CHoCH + price in premium
// Long: Morning was bearish + afternoon Bullish CHoCH + price in discount
bool play3_short = show_play3 and morning_trend == SMC_BULLISH and smc_currentAlerts.swingBearishCHoCH and in_premium and (in_kz2 or in_gt1)
bool play3_long = show_play3 and morning_trend == SMC_BEARISH and smc_currentAlerts.swingBullishCHoCH and in_discount and (in_kz2 or in_gt1)

// ── Active Play ───────────────────────────────────────────────────────────────
bool any_play_long = play1_long or play2_long or play3_long
bool any_play_short = play1_short or play2_short or play3_short
string active_play = any_play_long or any_play_short ? (play1_long or play1_short ? "1 回調狙擊" : play2_long or play2_short ? "2 流動性掃蕩" : "3 午後反轉") : "—"

// ── Play Visual Labels ────────────────────────────────────────────────────────
if play1_long
    label.new(chart.point.from_index(bar_index, low), "PLAY 1: 回調狙擊\nBuy OB test in Discount\nSL below OB " + str.tostring(bull_ob_low, format.mintick), color=color.new(color.green, 80), textcolor=color.white, style=label.style_label_up, size=size.small)
if play1_short
    label.new(chart.point.from_index(bar_index, high), "PLAY 1: 回調狙擊\nShort OB test in Premium\nSL above OB " + str.tostring(bear_ob_high, format.mintick), color=color.new(color.red, 80), textcolor=color.white, style=label.style_label_down, size=size.small)

if play2_long
    label.new(chart.point.from_index(bar_index, low), "PLAY 2: 流動性掃蕩\nPDL Sweep + Bullish CHoCH\nSL below sweep " + str.tostring(sweep_low, format.mintick), color=color.new(color.yellow, 70), textcolor=color.white, style=label.style_label_up, size=size.small)
if play2_short
    label.new(chart.point.from_index(bar_index, high), "PLAY 2: 流動性掃蕩\nPDH Sweep + Bearish CHoCH\nSL above sweep " + str.tostring(sweep_high, format.mintick), color=color.new(color.yellow, 70), textcolor=color.white, style=label.style_label_down, size=size.small)

if play3_long
    label.new(chart.point.from_index(bar_index, low), "PLAY 3: 午後反轉\nAfternoon Bullish CHoCH\nSL below " + str.tostring(smc_swingLow.currentLevel, format.mintick), color=color.new(color.orange, 70), textcolor=color.white, style=label.style_label_up, size=size.small)
if play3_short
    label.new(chart.point.from_index(bar_index, high), "PLAY 3: 午後反轉\nAfternoon Bearish CHoCH\nSL above " + str.tostring(smc_swingHigh.currentLevel, format.mintick), color=color.new(color.orange, 70), textcolor=color.white, style=label.style_label_down, size=size.small)

// ── Liquidity Sweep Visuals ───────────────────────────────────────────────────
if sweep_below_pdl and not na(prev_day_low)
    line.new(chart.point.from_index(bar_index - 3, prev_day_low), chart.point.from_index(bar_index, low), color=color.new(color.yellow, 50), style=line.style_dotted, width=2)
    label.new(chart.point.from_index(bar_index, low), "BSL Sweep", color=color(na), textcolor=color.yellow, style=label.style_label_up, size=size.tiny)

if sweep_above_pdh and not na(prev_day_high)
    line.new(chart.point.from_index(bar_index - 3, prev_day_high), chart.point.from_index(bar_index, high), color=color.new(color.yellow, 50), style=line.style_dotted, width=2)
    label.new(chart.point.from_index(bar_index, high), "SSL Sweep", color=color(na), textcolor=color.yellow, style=label.style_label_down, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
// R:R DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════

var float last_entry_price = na
var float last_sl_price = na
var float last_tp_price = na
var string last_direction = ""

if sniper_long or sniper_short
    last_entry_price := close
    last_direction := sniper_long ? "LONG" : "SHORT"

    // Find nearest OB for SL
    float ob_edge = na
    if smc_swingOBs.size() > 0
        for eachOB in smc_swingOBs
            if sniper_long and eachOB.bias == SMC_BULLISH
                ob_edge := nz(ob_edge, eachOB.barLow)
                if eachOB.barLow < nz(ob_edge, eachOB.barLow)
                    ob_edge := eachOB.barLow
            else if sniper_short and eachOB.bias == SMC_BEARISH
                ob_edge := nz(ob_edge, eachOB.barHigh)
                if eachOB.barHigh > nz(ob_edge, eachOB.barHigh)
                    ob_edge := eachOB.barHigh

    // Determine SL based on mode
    float sl_price = na
    if sniper_long
        float ob_sl = nz(ob_edge, smc_swingLow.currentLevel) - rr_buffer
        float swing_sl = nz(smc_swingLow.currentLevel, low) - rr_buffer
        // Smart toggle: if OB edge and swing are close, use swing
        bool use_swing = not na(ob_edge) and math.abs(nz(ob_edge, 0) - nz(smc_swingLow.currentLevel, 0)) < rr_smart_toggle_dist
        if rr_sl_mode == "Conservative (Swing+Buffer)" or use_swing
            sl_price := swing_sl
        else
            sl_price := ob_sl
    else if sniper_short
        float ob_sl = nz(ob_edge, smc_swingHigh.currentLevel) + rr_buffer
        float swing_sl = nz(smc_swingHigh.currentLevel, high) + rr_buffer
        bool use_swing = not na(ob_edge) and math.abs(nz(ob_edge, 0) - nz(smc_swingHigh.currentLevel, 0)) < rr_smart_toggle_dist
        if rr_sl_mode == "Conservative (Swing+Buffer)" or use_swing
            sl_price := swing_sl
        else
            sl_price := ob_sl

    last_sl_price := sl_price

    // TP: nearest liquidity target (PDH/PDL, EQH/EQL, or opposite swing)
    float tp = na
    if sniper_long
        tp := nz(prev_day_high, smc_swingHigh.currentLevel)
    else if sniper_short
        tp := nz(prev_day_low, smc_swingLow.currentLevel)
    last_tp_price := tp

// Draw entry/SL/TP lines on last signal
if not na(last_entry_price) and (barstate.islastconfirmedhistory or barstate.islast)
    int rr_right = bar_index + 20
    var line entry_line = line.new(na, na, na, na, color=color.new(color.white, 50), style=line.style_solid, width=2)
    var line sl_line = line.new(na, na, na, na, color=color.red, style=line.style_dashed, width=2)
    var line tp_line = line.new(na, na, na, na, color=color.green, style=line.style_dashed, width=2)
    var label entry_lbl = label.new(na, na, color=color(na), textcolor=color.white, style=label.style_label_left, size=size.tiny)
    var label sl_lbl = label.new(na, na, color=color(na), textcolor=color.red, style=label.style_label_left, size=size.tiny)
    var label tp_lbl = label.new(na, na, color=color(na), textcolor=color.green, style=label.style_label_left, size=size.tiny)

    entry_line.set_first_point(chart.point.from_index(bar_index, last_entry_price))
    entry_line.set_second_point(chart.point.from_index(rr_right, last_entry_price))
    entry_lbl.set_point(chart.point.from_index(rr_right, last_entry_price))
    entry_lbl.set_text("Entry: " + str.tostring(last_entry_price, format.mintick))

    if not na(last_sl_price)
        sl_line.set_first_point(chart.point.from_index(bar_index, last_sl_price))
        sl_line.set_second_point(chart.point.from_index(rr_right, last_sl_price))
        sl_lbl.set_point(chart.point.from_index(rr_right, last_sl_price))
        sl_lbl.set_text("SL: " + str.tostring(last_sl_price, format.mintick))

    if not na(last_tp_price)
        tp_line.set_first_point(chart.point.from_index(bar_index, last_tp_price))
        tp_line.set_second_point(chart.point.from_index(rr_right, last_tp_price))
        tp_lbl.set_point(chart.point.from_index(rr_right, last_tp_price))
        tp_lbl.set_text("TP: " + str.tostring(last_tp_price, format.mintick))

// Dashboard table
if show_rr_dashboard and not na(last_entry_price) and (barstate.islastconfirmedhistory or barstate.islast)
    float risk_pts = last_direction == "LONG" ? last_entry_price - nz(last_sl_price, last_entry_price) : nz(last_sl_price, last_entry_price) - last_entry_price
    float reward_pts = last_direction == "LONG" ? nz(last_tp_price, last_entry_price) - last_entry_price : last_entry_price - nz(last_tp_price, last_entry_price)
    float rr_ratio = risk_pts > 0 ? reward_pts / risk_pts : 0
    float risk_amount = rr_account_size * rr_risk_pct / 100
    float position_size = risk_pts > 0 ? risk_amount / risk_pts : 0
    bool rr_ok = rr_ratio >= rr_min_rr

    var table rr_tab = table.new(rr_dash_pos, 2, 10, color.new(color.black, 20), color.gray, 1, color.new(color.gray, 80), 1)
    table.cell(rr_tab, 0, 0, "Play", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 0, active_play, text_color=any_play_long ? color.green : any_play_short ? color.red : color.gray, text_size=size.small)
    table.cell(rr_tab, 0, 1, "Direction", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 1, last_direction, text_color=last_direction == "LONG" ? color.green : color.red, text_size=size.small)
    table.cell(rr_tab, 0, 2, "Entry", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 2, str.tostring(last_entry_price, format.mintick), text_color=color.white, text_size=size.small)
    table.cell(rr_tab, 0, 3, "SL", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 3, str.tostring(last_sl_price, format.mintick), text_color=color.red, text_size=size.small)
    table.cell(rr_tab, 0, 4, "TP1", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 4, str.tostring(last_tp_price, format.mintick), text_color=color.green, text_size=size.small)
    table.cell(rr_tab, 0, 5, "R:R", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 5, "1:" + str.tostring(rr_ratio, "#.##"), text_color=rr_ok ? color.green : color.red, text_size=size.small)
    table.cell(rr_tab, 0, 6, "Size", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 6, str.tostring(position_size, "#.##") + " lots", text_color=color.white, text_size=size.small)
    table.cell(rr_tab, 0, 7, "Mode", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 7, rr_sl_mode == "Aggressive (OB+Buffer)" ? "Aggressive" : "Conservative", text_color=color.orange, text_size=size.small)
    string zone_text = in_kz1 ? "早市 KZ" : in_gt1 ? "午間 GT" : in_kz2 ? "午後 KZ" : in_gt2 ? "收市 GT" : "Off-hours"
    color zone_color = in_kz1 ? color.green : in_gt1 ? color.gray : in_kz2 ? color.yellow : in_gt2 ? color.red : color.gray
    table.cell(rr_tab, 0, 8, "Zone", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 8, zone_text, text_color=zone_color, text_size=size.small)
    string trend_text = smc_swingTrend.bias == SMC_BULLISH ? "Bullish ↑" : smc_swingTrend.bias == SMC_BEARISH ? "Bearish ↓" : "Neutral"
    color trend_color = smc_swingTrend.bias == SMC_BULLISH ? color.green : smc_swingTrend.bias == SMC_BEARISH ? color.red : color.gray
    table.cell(rr_tab, 0, 9, "Trend", text_color=color.gray, text_size=size.small)
    table.cell(rr_tab, 1, 9, trend_text, text_color=trend_color, text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
