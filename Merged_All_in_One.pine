    long_score += (eff_respectci and ci_filter) ? 1 : 0
    long_score += (eff_respectroc and roc_long) ? 1 : 0
    long_score += (eff_respectht and halftrend_long) ? 1 : 0
    long_score += (eff_respectdonchian and donchian_long) ? 1 : 0
    long_score += (eff_respecttrendline_breakout and tb_buysignal) ? 1 : 0
    long_score += (eff_respectbbpt and bbpt_long) ? 1 : 0
    long_score += (eff_respectrqk and rqkuptrend) ? 1 : 0
    long_score += (eff_respectbx and bx_long) ? 1 : 0
    long_score += (eff_respectbbosc and bbosc_long) ? 1 : 0
    long_score += (eff_respectwae and wae_long) ? 1 : 0
    long_score += (eff_respectce and ce_long) ? 1 : 0
    long_score += (eff_respectssl and ssl_long) ? 1 : 0
    long_score += (eff_respect2ma and ema2_long) ? 1 : 0
    long_score += (eff_respect3ma and ema3_long) ? 1 : 0
    long_score += (eff_respectstochastic and stoch_long) ? 1 : 0
    long_score += (eff_respectcci and ccilong) ? 1 : 0
    long_score += (eff_respectst and isstup) ? 1 : 0
    long_score += (eff_respectrsi and rsiup) ? 1 : 0
    long_score += (eff_respectrsimalimit and rsimalimitlong) ? 1 : 0
    long_score += (eff_respectrsilimit and rsilimitlong) ? 1 : 0
    long_score += (eff_respectrsima and rsimalong2) ? 1 : 0
    long_score += (eff_respectema and isaboverespectema) ? 1 : 0
    long_score += (eff_respectqqe and isqqeabove) ? 1 : 0
    long_score += (eff_respectsar and sarup) ? 1 : 0
    long_score += (eff_respectvol and longvol) ? 1 : 0
    long_score += (eff_respectchaikin and chaikin_long) ? 1 : 0
    long_score += (eff_respectvwap and long_vwap) ? 1 : 0
    long_score += (eff_respectvo and vo_long) ? 1 : 0
    long_score += (eff_respectao and ao_long) ? 1 : 0
    long_score += (eff_respectsuperichi and superichi_long) ? 1 : 0
    long_score += (eff_respectwolf and wolf_long) ? 1 : 0
    long_score += (eff_respectichi and ichi_long) ? 1 : 0
    long_score += (eff_respectmacd and ismacdup) ? 1 : 0
    long_score += (eff_respecthull and hullup) ? 1 : 0
    long_score += (eff_respectvi and vipcondition) ? 1 : 0
    long_score += (eff_respectstc and stcup) ? 1 : 0
    long_score += (eff_respectdv and dvup) ? 1 : 0
    long_score += (eff_respectsmc and smc_conf_long) ? 1 : 0
    long_score += (eff_respectsmc_htf and smc_htf_conf_long) ? 1 : 0
    long_score += (eff_respectob_mit and smc_ob_bear_mitigated) ? 1 : 0
    long_score += (eff_respectbc and bc_bullishBreakout) ? 1 : 0
    long_score += (eff_respectvix and vix_conf_long) ? 1 : 0
    long_score += (eff_respectsqz and sqz_conf_long) ? 1 : 0
    long_score += (eff_respectsqz_active and sqz_active_conf_long) ? 1 : 0
    long_score += (eff_respectsession and session_conf_long) ? 1 : 0
    long_score += (eff_respectfv_ob and fv_ob_conf_long) ? 1 : 0
    long_score += (eff_respecttm and tm_conf_long) ? 1 : 0

    short_score += (eff_respectrf and downrf) ? 1 : 0
    short_score += (eff_respectadx and adxdowncondition) ? 1 : 0
    short_score += (eff_respecttsi and tsi_short) ? 1 : 0
    short_score += (eff_respecthacolt and hacolt_short) ? 1 : 0
    short_score += (eff_respectmd and md_short) ? 1 : 0
    short_score += (eff_respecttdfi and tdfi_short) ? 1 : 0
    short_score += (eff_respectdpo and dpo_short) ? 1 : 0
    short_score += (eff_respectrd and rd_signal) ? 1 : 0
    short_score += (eff_respectci and ci_filter) ? 1 : 0
    short_score += (eff_respectroc and roc_short) ? 1 : 0
    short_score += (eff_respectht and halftrend_short) ? 1 : 0
    short_score += (eff_respectdonchian and donchian_short) ? 1 : 0
    short_score += (eff_respecttrendline_breakout and tb_sellsignal) ? 1 : 0
    short_score += (eff_respectbbpt and bbpt_short) ? 1 : 0
    short_score += (eff_respectrqk and rqkdowntrend) ? 1 : 0
    short_score += (eff_respectbx and bx_short) ? 1 : 0
    short_score += (eff_respectbbosc and bbosc_short) ? 1 : 0
    short_score += (eff_respectwae and wae_short) ? 1 : 0
    short_score += (eff_respectce and ce_short) ? 1 : 0
    short_score += (eff_respectssl and ssl_short) ? 1 : 0
    short_score += (eff_respect2ma and ema2_short) ? 1 : 0
    short_score += (eff_respect3ma and ema3_short) ? 1 : 0
    short_score += (eff_respectstochastic and stoch_short) ? 1 : 0
    short_score += (eff_respectcci and ccishort) ? 1 : 0
    short_score += (eff_respectrsimalimit and rsimalimitshort) ? 1 : 0
    short_score += (eff_respectrsilimit and rsilimitshort) ? 1 : 0
    short_score += (eff_respectrsima and rsimashort2) ? 1 : 0
    short_score += (eff_respectst and isstdown) ? 1 : 0
    short_score += (eff_respectrsi and rsidown) ? 1 : 0
    short_score += (eff_respectema and isbelowrespectema) ? 1 : 0
    short_score += (eff_respectqqe and isqqebelow) ? 1 : 0
    short_score += (eff_respectsar and sardown) ? 1 : 0
    short_score += (eff_respectvol and shortvol) ? 1 : 0
    short_score += (eff_respectchaikin and chaikin_short) ? 1 : 0
    short_score += (eff_respectvwap and short_vwap) ? 1 : 0
    short_score += (eff_respectvo and vo_short) ? 1 : 0
    short_score += (eff_respectao and ao_short) ? 1 : 0
    short_score += (eff_respectsuperichi and superichi_short) ? 1 : 0
    short_score += (eff_respectwolf and wolf_short) ? 1 : 0
    short_score += (eff_respectichi and ichi_short) ? 1 : 0
    short_score += (eff_respectmacd and ismacddown) ? 1 : 0
    short_score += (eff_respecthull and hulldown) ? 1 : 0
    short_score += (eff_respectvi and vimcondition) ? 1 : 0
    short_score += (eff_respectstc and stcdown) ? 1 : 0
    short_score += (eff_respectdv and dvup) ? 1 : 0
    short_score += (eff_respectsmc and smc_conf_short) ? 1 : 0
    short_score += (eff_respectsmc_htf and smc_htf_conf_short) ? 1 : 0
    short_score += (eff_respectob_mit and smc_ob_bull_mitigated) ? 1 : 0
    short_score += (eff_respectbc and bc_bearishBreakout) ? 1 : 0
    short_score += (eff_respectvix and vix_conf_short) ? 1 : 0
    short_score += (eff_respectsqz and sqz_conf_short) ? 1 : 0
    short_score += (eff_respectsqz_active and sqz_active_conf_short) ? 1 : 0
    short_score += (eff_respectsession and session_conf_short) ? 1 : 0
    short_score += (eff_respectfv_ob and fv_ob_conf_short) ? 1 : 0
    short_score += eff_respecttm and tm_conf_short ? 1 : 0

    longCond := leadinglongcond and long_score >= signal_score_threshold
    shortCond := leadingshortcond and short_score >= signal_score_threshold

 


var int leadinglong_count = 0
var int leadinglong_count2 = 0

var int leadingshort_count = 0
var int leadingshort_count2 = 0


if leadinglongcond
    leadinglong_count := leadinglong_count + 1
    leadinglong_count2 := leadinglong_count

for i = 1 to 100
    if leadinglongcond[i]
        leadinglong_count := leadinglong_count + 1
        leadinglong_count2 := leadinglong_count

    else
        leadinglong_count := 0
        break


if leadingshortcond
    leadingshort_count := leadingshort_count + 1
    leadingshort_count2 := leadingshort_count

for i = 1 to 100
    if leadingshortcond[i]
        leadingshort_count := leadingshort_count + 1
        leadingshort_count2 := leadingshort_count

    else
        leadingshort_count := 0
        break

CondIni = 0

// Session filter
in_session = na(time(timeframe.period, session_time)) == false
session_conf_long := in_session
session_conf_short := in_session

longCondition = false
shortCondition = false




// if expiry option is used
longcond_withexpiry = longCond and leadinglong_count2 <= signalexpiry
shortcond_withexpiry = shortCond and leadingshort_count2 <= signalexpiry

//log.info("leadinglong_count2 : {0}",leadinglong_count2)
//log.info("leadingshort_count2: {0}",leadingshort_count2)
//without expiry
longCondition := longcond_withexpiry and CondIni[1] == -1 
shortCondition := shortcond_withexpiry and CondIni[1] == 1



if alternatesignal
    longCondition := longcond_withexpiry and CondIni[1] == -1  
    shortCondition := shortcond_withexpiry and CondIni[1] == 1 

else
    longCondition := longcond_withexpiry  
    shortCondition := shortcond_withexpiry 



CondIni := longcond_withexpiry ? 1 : shortcond_withexpiry ? -1 : CondIni[1]


is_expiry_count_crossed_long = leadinglong_count2 >= signalexpiry 
is_expiry_count_crossed_short = leadingshort_count2 >= signalexpiry 

 



plotshape(showsignal ? (longCondition[1] ? false : longCondition) : false, title='Buy Signal', text='long', textcolor=color.new(color.white, 0), style=shape.labelup, size=size.tiny, location=location.belowbar, color=color.new(color.green, 0))
plotshape(showsignal and shortCondition and showsignal, title='Sell Signal', text='short', textcolor=color.new(color.white, 0), style=shape.labeldown, size=size.tiny, location=location.abovebar, color=color.new(color.red, 0))

alertcondition(longCondition, title='Buy Alert', message='BUY')
alertcondition(shortCondition, title='Sell Alert', message='SELL')
alertcondition(longCondition or shortCondition, title='Buy or Sell Alert', message="Buy or Sell Alert")

 
rsitype2 = rsitype
if rsitype2 == "RSI Level"
    rsitype2 := "RSI Level (" + str.tostring(respectrsilevel) +")"


confirmation_counter = array.new_string(0)
confirmation_val = array.new_string(0)
confirmation_val_short = array.new_string(0)





pushConfirmation(respect, label, longCondition, shortCondition) =>
    if respect
        array.push(confirmation_counter, label)
        array.push(confirmation_val, longCondition ? "✔️" : "❌")
        array.push(confirmation_val_short, shortCondition ? "✔️" : "❌")

pushConfirmation(eff_respectema, "EMA", isaboverespectema, isbelowrespectema)
pushConfirmation(eff_respect2ma, "2 EMA Cross (" + str.tostring(respect2maperiod_1) + "," + str.tostring(respect2maperiod_2) + ")", ema2_long, ema2_short)
pushConfirmation(eff_respect3ma, "3 EMA Cross (" + str.tostring(respect3maperiod_1) + "," + str.tostring(respect3maperiod_2) + "," + str.tostring(respect3maperiod_3) + ")", ema3_long, ema3_short)
pushConfirmation(eff_respectrf, "Range Filter", uprf, downrf)
pushConfirmation(eff_respectrqk, "Rational Quadratic Kernel (RQK)", rqkuptrend, rqkdowntrend)
pushConfirmation(eff_respectst, "SuperTrend", isstup, isstdown)
pushConfirmation(eff_respectht, "Half Trend", halftrend_long, halftrend_short)
 
pushConfirmation(eff_respecttrendline_breakout, "Trendline breakout", tb_buysignal, tb_sellsignal)
pushConfirmation(eff_respectrd, "Range Detector", rd_long, rd_short)
pushConfirmation(eff_respecthacolt, "Heiken-Ashi Candlestick Oscillator", hacolt_long, hacolt_short)


pushConfirmation(eff_respectdonchian, "Donchian Trend Ribbon", donchian_long, donchian_short)
pushConfirmation(eff_respectroc, "Rate of Change (ROC)", roc_long, roc_short)
pushConfirmation(eff_respecttsi, "True Strength Indicator (TSI)", tsi_long, tsi_short)

pushConfirmation(eff_respecttdfi, "Trend Direction Force Index (TDFI)", tdfi_long, tdfi_short)


pushConfirmation(eff_respectbx, "B-Xtrender (" + str.tostring(bxtype) + ")", bx_long, bx_short)
pushConfirmation(eff_respectbbpt, "Bull Bear Power Trend (" + str.tostring(bbpttype) + ")", bbpt_long, bbpt_short)
pushConfirmation(eff_respectvwap, "VWAP", long_vwap, short_vwap)
pushConfirmation(eff_respectichi, "Ichimoku Cloud", ichi_long, ichi_short)
pushConfirmation(eff_respectsuperichi, "Superichi", superichi_long, superichi_short)
pushConfirmation(eff_respectbbosc, "BB Oscillator", bbosc_long, bbosc_short)
pushConfirmation(eff_respectce, "Chandelier Exit", ce_long, ce_short)
pushConfirmation(eff_respectcci, "CCI", ccilong, ccishort)
pushConfirmation(eff_respectadx, "DMI (Adx)  (" + str.tostring(adxtype) + ")", adxupcondition, adxdowncondition)
pushConfirmation(eff_respectsar, "Parabolic SAR", sarup, sardown)
pushConfirmation(eff_respectssl, "SSL Channel", ssl_long, ssl_short)
pushConfirmation(eff_respectvo, "Volatility Oscillator", vo_long, vo_short)
pushConfirmation(eff_respectdpo, "Detrended Price Oscillator(DPO)", dpo_long, dpo_short)
pushConfirmation(eff_respectmd, "McGinley Dynamic", md_long, md_short)

pushConfirmation(eff_respectdv, "DV", dvup, dvup) // Note: Both are 'dvup'. Double-check if it's intended.
pushConfirmation(eff_respectci, "Choppiness Index", ci_filter, ci_filter) // Note: Both are 'dvup'. Double-check if it's intended.

pushConfirmation(eff_respectstochastic, "Stochastic (" + str.tostring(stochtype) + ")", stoch_long, stoch_short)
pushConfirmation(eff_respectrsi, "RSI (" + str.tostring(rsitype2) + ")", rsiup, rsidown)
pushConfirmation(eff_respectmacd, "MACD (" + str.tostring(macdtype) + ")", ismacdup, ismacddown)
pushConfirmation(eff_respectstc, "Schaff Trend Cycle", stcup, stcdown)
pushConfirmation(eff_respectwae, "Waddah Attar Explosion", wae_long, wae_short)

pushConfirmation(eff_respectchaikin, "Chaikin Money Flow", chaikin_long, chaikin_short)
pushConfirmation(eff_respectvol, "Volume", longvol, shortvol)
pushConfirmation(eff_respectao, "Awesome Oscillator(" + str.tostring(aotype) + ")", ao_long, ao_short)
pushConfirmation(eff_respectwolf, "Wolfpack Id", wolf_long, wolf_short)
pushConfirmation(eff_respectqqe, "QQE Mod (" + str.tostring(qqetype) + ")", isqqeabove, isqqebelow)
pushConfirmation(eff_respecthull, "HullSuite", hullup, hulldown)
pushConfirmation(eff_respectvi, "Vortex Index  (" + str.tostring(vitype) + ")", vipcondition, vimcondition)
pushConfirmation(eff_respectsmc, "Smart Money Concepts", smc_conf_long, smc_conf_short)
pushConfirmation(eff_respectsmc_htf, "SMC HTF Trend (" + smc_htf_timeframe + ")", smc_htf_conf_long, smc_htf_conf_short)
pushConfirmation(eff_respectob_mit, "OB Mitigation", smc_ob_bear_mitigated, smc_ob_bull_mitigated)
pushConfirmation(eff_respectbc, "Breakout Channels", bc_bullishBreakout, bc_bearishBreakout)
pushConfirmation(eff_respectvix, "Williams Vix Fix", vix_conf_long, vix_conf_short)
pushConfirmation(eff_respectsqz, "Squeeze Momentum", sqz_conf_long, sqz_conf_short)
pushConfirmation(eff_respectsqz_active, "Squeeze Not Active", sqz_active_conf_long, sqz_active_conf_short)
pushConfirmation(eff_respectsession, "Session Filter", session_conf_long, session_conf_short)
pushConfirmation(eff_respectfv_ob, "FVG-OB Confluence", fv_ob_conf_long, fv_ob_conf_short)
pushConfirmation(eff_respecttm, "Trend Meter", tm_conf_long, tm_conf_short)



getFalseShortConditionItems(arrShort) =>
    sShort = ""
    if array.size(arrShort) > 0
        for i = 0 to array.size(arrShort) - 1
            if array.get(arrShort, i) == "❌"
                sShort := sShort + array.get(confirmation_counter, i) + "\n"
    sShort


labelShortCondition = showsignal and is_expiry_count_crossed_short and not is_expiry_count_crossed_short[1] and CondIni == 1

if labelShortCondition
    falseShortConditionString = getFalseShortConditionItems(confirmation_val_short)
    tooltipS = "🔴 Failed Short Confirmations: " + "\n" + "--------------------------" + "\n" + falseShortConditionString
    label.new(bar_index, low, "🔴", color=color.new(#dd1111, 0), textcolor=color.white, style=label.style_none, yloc=yloc.belowbar, size=size.small, tooltip=tooltipS)



getFalseLongConditionItems(arr) =>
    s = ""
    if array.size(arr) > 0
        for i = 0 to array.size(arr) - 1
            if array.get(arr, i) == "❌"
                s := s + array.get(confirmation_counter, i) + "\n"
    s


labelCondition = showsignal and is_expiry_count_crossed_long and not is_expiry_count_crossed_long[1] and CondIni == -1

if labelCondition
    falseLongConditionString = getFalseLongConditionItems(confirmation_val)
    tooltipL = "🔴 Failed Long Confirmations: " + "\n" + "--------------------------" + "\n" + falseLongConditionString
    label.new(bar_index, high, "🔴", color=color.new(color.green, 0), textcolor=color.white, style=label.style_none, yloc=yloc.abovebar, size=size.small, tooltip=tooltipL)






leadingstatus = leadinglongcond ? "✔️" : "❌"
leadingstatus_short = leadingshortcond ? "✔️" : "❌"


rowcount = int(na)
if array.size(confirmation_counter) ==0
    rowcount := 5
else
    rowcount := array.size(confirmation_counter)+4


var table tab1 = table.new(i_tab1Ypos + '_' + i_tab1Xpos, 3, rowcount, color.rgb(42, 46, 57), color.rgb(204, 204, 204), 0, color.rgb(77, 71, 71), 1)
if showdashboard and barstate.islast


    table.cell(tab1, 1, 0,"Long", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(61, 189, 72),text_color=color.white)
    table.cell(tab1, 2, 0,"Short", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(243, 77, 77),text_color=color.white)


    table.cell(tab1, 0, 1, "Leading Indicator", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67),text_color=color.white)
    table.cell(tab1, 1, 1,"", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67),text_color=color.white)
    table.cell(tab1, 2, 1,"", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67),text_color=color.white)


    table.cell(tab1, 0, 2, leadingindicator, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab1, 1, 2, leadingstatus, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab1, 2, 2, leadingstatus_short, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)


    table.cell(tab1, 0, 3, "Confirmation Indicators", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67),text_color=color.white)
    table.cell(tab1, 1, 3, "", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67),text_color=color.white)
    table.cell(tab1, 2, 3, "", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67),text_color=color.white)

    if array.size(confirmation_counter) > 0
        for i=0 to array.size(confirmation_counter)-1
            table.cell(tab1, 0, 4+i, array.get(confirmation_counter,i), text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    else
        table.cell(tab1, 0, 4, "None Selected", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)


    if array.size(confirmation_val) > 0
        for j=0 to array.size(confirmation_val)-1
            table.cell(tab1, 1, 4+j, array.get(confirmation_val,j), text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
            table.cell(tab1, 2, 4+j, array.get(confirmation_val_short,j), text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)


plot(longCondition?100:na, "long Signal",display = display.data_window )
plot(shortCondition?-100:na, "Short Signal",display = display.data_window )

// Detailed indicator status dashboard
if show_detailed_dashboard and barstate.islast
    var table tab2 = table.new(position.bottom_right, 2, 7, color.rgb(42, 46, 57), color.rgb(204, 204, 204), 0, color.rgb(77, 71, 71), 1)
    table.cell(tab2, 0, 0, "Indicator Status", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67), text_color=color.white)
    table.cell(tab2, 1, 0, "State", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), bgcolor=color.rgb(68, 68, 67), text_color=color.white)
    // SMC
    smc_status = smc_conf_long ? "Bullish" : smc_conf_short ? "Bearish" : "Neutral"
    smc_color = smc_conf_long ? color.green : smc_conf_short ? color.red : color.gray
    table.cell(tab2, 0, 1, "SMC Trend", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab2, 1, 1, smc_status, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=smc_color)
    // Breakout Channels
    bc_status = bc_bullishBreakout ? "Bull Breakout" : bc_bearishBreakout ? "Bear Breakout" : bc_boxes.size() > 0 ? "In Channel" : "None"
    bc_color = bc_bullishBreakout ? color.green : bc_bearishBreakout ? color.red : color.gray
    table.cell(tab2, 0, 2, "Breakout Ch.", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab2, 1, 2, bc_status, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=bc_color)
    // Vix Fix
    vix_status = vix_conf_long ? "Normal" : vix_conf_short ? "Elevated" : "N/A"
    vix_color = vix_conf_long ? color.green : vix_conf_short ? color.red : color.gray
    table.cell(tab2, 0, 3, "Vix Fix", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab2, 1, 3, vix_status, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=vix_color)
    // Squeeze
    sqz_status = sqzOn ? "Squeezing" : sqz_val > 0 ? "Released Bull" : sqz_val < 0 ? "Released Bear" : "N/A"
    sqz_color = sqzOn ? color.orange : sqz_val > 0 ? color.green : sqz_val < 0 ? color.red : color.gray
    table.cell(tab2, 0, 4, "Squeeze", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab2, 1, 4, sqz_status, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=sqz_color)
    // EMA
    ema_status = switch_ema and len1bool ? (close > ema1 ? "Above" : "Below") : "Off"
    ema_color = switch_ema and len1bool ? (close > ema1 ? color.green : color.red) : color.gray
    table.cell(tab2, 0, 5, "EMA", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab2, 1, 5, ema_status, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=ema_color)
    // STC
    stc_status = not na(stc_val) ? (stc_val >= stc_upper_band ? "Overbought" : stc_val <= stc_lower_band ? "Oversold" : "Neutral") : "Off"
    stc_color = not na(stc_val) ? (stc_val >= stc_upper_band ? color.green : stc_val <= stc_lower_band ? color.red : color.orange) : color.gray
    table.cell(tab2, 0, 6, "STC", text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=color.white)
    table.cell(tab2, 1, 6, stc_status, text_halign=text.align_left, text_size=table_size(in_dashboardtab_size), text_color=stc_color)

// SMC Alerts
alertcondition(smc_currentAlerts.swingBullishBOS, 'SMC Bullish BOS', 'Swing Bullish BOS formed')
alertcondition(smc_currentAlerts.swingBullishCHoCH, 'SMC Bullish CHoCH', 'Swing Bullish CHoCH formed')
alertcondition(smc_currentAlerts.swingBearishBOS, 'SMC Bearish BOS', 'Swing Bearish BOS formed')
alertcondition(smc_currentAlerts.swingBearishCHoCH, 'SMC Bearish CHoCH', 'Swing Bearish CHoCH formed')
alertcondition(smc_currentAlerts.equalHighs, 'SMC Equal Highs', 'Equal highs detected')
alertcondition(smc_currentAlerts.equalLows, 'SMC Equal Lows', 'Equal lows detected')
alertcondition(smc_htf_conf_long and smc_htf_conf_long[1] != true, 'SMC HTF Trend Bullish', 'Higher-timeframe SMC trend turned bullish')
alertcondition(smc_htf_conf_short and smc_htf_conf_short[1] != true, 'SMC HTF Trend Bearish', 'Higher-timeframe SMC trend turned bearish')
alertcondition(smc_ob_bear_mitigated, 'SMC Bearish OB Mitigated', 'Bearish order block was mitigated - bullish signal')
alertcondition(smc_ob_bull_mitigated, 'SMC Bullish OB Mitigated', 'Bullish order block was mitigated - bearish signal')
alertcondition(fv_ob_conf_long, 'FVG-OB Bullish Confluence', 'Price in bullish FVG-OB confluence zone')
alertcondition(fv_ob_conf_short, 'FVG-OB Bearish Confluence', 'Price in bearish FVG-OB confluence zone')
alertcondition(bc_bullishBreakout, 'BC Bullish Breakout', 'Price broke above channel')
alertcondition(bc_bearishBreakout, 'BC Bearish Breakout', 'Price broke below channel')
alertcondition(bc_newChannel, 'BC New Channel', 'New breakout channel formed')
alertcondition(vix_long, 'Vix Fix Bottom Signal', 'Potential market bottom detected')
alertcondition(vix_short, 'Vix Fix Exhaustion Signal', 'Vix Fix dropped from elevated - exhaustion')
alertcondition(sqz_long, 'Squeeze Release Bull', 'Squeeze released with bullish momentum')
alertcondition(sqz_short, 'Squeeze Release Bear', 'Squeeze released with bearish momentum')
alertcondition(ema_cross_up, 'EMA Cross Up', 'Fast MA crossed above Slow MA')
alertcondition(ema_cross_dn, 'EMA Cross Down', 'Fast MA crossed below Slow MA')
alertcondition(tm_long, 'Trend Meter Bullish Align', 'Trend meters aligned bullish')
alertcondition(tm_short, 'Trend Meter Bearish Align', 'Trend meters aligned bearish')

// ============================================================================
// Data Window Outputs (for external strategy consumption)
// ============================================================================
plot(longCondition ? 1 : 0, "Long Signal", display=display.data_window)
plot(shortCondition ? -1 : 0, "Short Signal", display=display.data_window)
plot(use_signal_scoring ? long_score : na, "Long Score", display=display.data_window)
plot(use_signal_scoring ? short_score : na, "Short Score", display=display.data_window)
plot(smc_conf_long ? 1 : smc_conf_short ? -1 : 0, "SMC Bias", display=display.data_window)
plot(smc_htf_conf_long ? 1 : smc_htf_conf_short ? -1 : 0, "SMC HTF Bias", display=display.data_window)
plot(bc_bullishBreakout ? 1 : bc_bearishBreakout ? -1 : 0, "BC Breakout", display=display.data_window)
plot(vix_conf_long ? 1 : vix_conf_short ? -1 : 0, "Vix Fix Bias", display=display.data_window)
plot(sqz_conf_long ? 1 : sqz_conf_short ? -1 : 0, "Squeeze Bias", display=display.data_window)
plot(not na(stc_val) ? stc_val : na, "STC Value", display=display.data_window)
plot(in_session ? 1 : 0, "In Session", display=display.data_window)
plot(tm_conf_long ? 1 : tm_conf_short ? -1 : 0, "Trend Meter Bias", display=display.data_window)
