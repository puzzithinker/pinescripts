// Preset overrides: effective values that combine user input with preset selection
// When preset != "Custom", override the relevant respect* values
// Preset effective variables — compute preset flags once, then use simple or
is_all_filters   = preset == "All Filters"
is_smc_scalper   = preset == "SMC Scalper"
is_trend_follow  = preset == "Trend Follower"
is_breakout_tr   = preset == "Breakout Trader"

bool eff_respectema        = is_trend_follow or is_all_filters or respectema
bool eff_respect2ma        = is_trend_follow or is_all_filters or respect2ma
bool eff_respect3ma        = is_all_filters or respect3ma
bool eff_respectrf         = is_breakout_tr or is_all_filters or respectrf
bool eff_respectrqk        = is_all_filters or respectrqk
bool eff_respectst         = is_trend_follow or is_all_filters or respectst
bool eff_respectht         = is_all_filters or respectht
bool eff_respectdonchian   = is_all_filters or respectdonchian
bool eff_respectroc        = is_all_filters or respectroc
bool eff_respecttsi        = is_all_filters or respecttsi
bool eff_respecttdfi       = is_all_filters or respecttdfi
bool eff_respectmd         = is_all_filters or respectmd
bool eff_respectdpo        = is_all_filters or respectdpo
bool eff_respectichi       = is_all_filters or respectichi
bool eff_respectsuperichi  = is_all_filters or respectsuperichi
bool eff_respecttrendline_breakout = is_all_filters or respecttrendline_breakout
bool eff_respectrd         = is_all_filters or respectrd
bool eff_respecthacolt     = is_all_filters or respecthacolt
bool eff_respectbx         = is_all_filters or respectbx
bool eff_respectbbpt       = is_all_filters or respectbbpt
