splitSessionString(sessXTime) =>
    //session stirng looks like this: 0000-0000:1234567 ie start time, end time, day of the week
    //we need to parse the sessXTime string into hours and min for start and end times so we can use those in the timestampfunction below

    //string times contains "0000-2300" as an example
    string times = array.get(str.split(sessXTime, ':'), 0)

    //string startTime contains "0000"
    string startTime = array.get(str.split(times, '-'), 0)
    //string endTime contains "2300"
    string endTime = array.get(str.split(times, '-'), 1)

    //now we need to get the start hour and start min, sing 0 index - hour is the characters in index 0 and index 1 while min is the chars at index 2 and 3
    string[] startTimeChars = str.split(startTime, '')
    string[] endTimeChars = str.split(endTime, '')

    //so now startHour contains 00 and start min contains 00
    string startHour = array.get(startTimeChars, 0) + array.get(startTimeChars, 1)
    string startMin = array.get(startTimeChars, 2) + array.get(startTimeChars, 3)

    //so now endHour contains 23 and end min contains 00
    string endHour = array.get(endTimeChars, 0) + array.get(endTimeChars, 1)
    string endMin = array.get(endTimeChars, 2) + array.get(endTimeChars, 3)
    [startHour, startMin, endHour, endMin]
    
calc_session_startend(sessXTime, gmt) =>
    [startHour, startMin, endHour, endMin] = splitSessionString(sessXTime)
    targetstartTimeX = timestamp(gmt, year, month, dayofmonth, math.round(str.tonumber(startHour)), math.round(str.tonumber(startMin)), 00)
    targetendTimeX = timestamp(gmt, year, month, dayofmonth, math.round(str.tonumber(endHour)), math.round(str.tonumber(endMin)), 00)
    time_now = timestamp(year, month, dayofmonth, hour, minute, 00) 
    midnight_exchange = timestamp(year, month, dayofmonth, 00, 00, 00)  


    //if start hour is greater than end hour we are dealing with a session that starts towards the end of one day 
    //and ends the next day. ie advance the end time by 24 hours - its the next day
    bool adjusted = false
    if gmt == 'GMT+0'
        if math.round(str.tonumber(startHour)) > math.round(str.tonumber(endHour))
            if time_now - targetstartTimeX >= 0
                targetendTimeX := targetendTimeX + 24 * 60 * 60 * 1000
                adjusted := true
                targetendTimeX
    if gmt == 'GMT+1'
        if math.round(str.tonumber(startHour)) == 0
            startHour := '24'
        if math.round(str.tonumber(endHour)) == 0
            endHour := '24'    
        if math.round(str.tonumber(startHour))-1 > math.round(str.tonumber(endHour))-1
            if time_now - targetstartTimeX >= 0
                targetendTimeX := targetendTimeX + 24 * 60 * 60 * 1000
                adjusted := true
                targetendTimeX
    

    
    if targetstartTimeX < midnight_exchange and midnight_exchange < targetendTimeX and not adjusted
        targetendTimeX := targetendTimeX + 24 * 60 * 60 * 1000
        targetendTimeX                
            
    [targetstartTimeX,targetendTimeX]
                

draw_open_range(sessXTime, sessXcol, show_orX, gmt)=>
    if show_orX
        // Initialize variables on bar zero only, so they preserve their values across bars.
        var hi = float(na)
        var lo = float(na)
        var box hiLoBox = na
        // Detect changes in timeframe.
        session = time(timeframe.period, sessXTime, gmt)
        bool newTF = not na(session) and na(session[1])
        if newTF
            // New bar in higher timeframe; reset values and create new lines and box.
            [targetstartTimeX,targetendTimeX] = calc_session_startend(sessXTime, gmt)
            sessionDuration = math.round(math.abs(time  - targetendTimeX)/(timeframe.multiplier*60*1000))
   
            hi := high
            lo := low
            hiLoBox := box.new(bar_index, hi, timeframe.multiplier == 1? bar_index : bar_index+sessionDuration, lo, border_color = na, bgcolor = sessXcol)
            int(na)
        else
            if timeframe.multiplier == 1 and (na(session[1]) and not na(session) or session[1] < session)
                box.set_right(hiLoBox, bar_index+1)
            int(na)
draw_session_hilo(sessXTime, show_rectangleX, show_labelX, sessXcolLabel, sessXLabel, gmt)=>
    if show_rectangleX
        // Initialize variables on bar zero only, so they preserve their values across bars.
        var hi = float(0)
        var lo = float(10000000000.0)
       
        var line line_t = na
        var line line_b = na
        var label line_label = na
        // var box hiLoBox = na
        // Detect changes in timeframe.
        session = time(timeframe.period, sessXTime, gmt)
        sessLineStyleX = rectStyle == 'Solid' ? line.style_solid : line.style_dashed
        bool newTF = not na(session) and na(session[1])
        hi := newTF ? high : bool(session) ? math.max(high, hi[1]) : hi[1]
        lo := newTF ? low : bool(session) ? math.min(low, lo[1]) : lo[1]
          
        if newTF
            beginIndex = bar_index 
            [targetstartTimeX,targetendTimeX] = calc_session_startend(sessXTime, gmt)
            sessionDuration = math.round(math.abs(time  - targetendTimeX)/(timeframe.multiplier*60*1000))
        
            line_t := line.new(beginIndex, hi, timeframe.multiplier == 1? bar_index : bar_index+sessionDuration, hi, xloc=xloc.bar_index, style=sessLineStyleX, color=sessXcolLabel)
            line_b := line.new(beginIndex, lo, timeframe.multiplier == 1? bar_index : bar_index+sessionDuration, lo, xloc=xloc.bar_index, style=sessLineStyleX, color=sessXcolLabel)
            line.delete(line_t[1])
            line.delete(line_b[1])
            if show_labelX
                line_label := label.new(beginIndex, hi, sessXLabel, xloc=xloc.bar_index, textcolor=sessXcolLabel, style=label.style_none, size=size.normal, textalign=text.align_right)
                label.delete(line_label[1])
  
            int(na)
        else
            if na(session[1]) and not na(session) or session[1] < session
                if timeframe.multiplier == 1
                    line.set_x2(line_t,bar_index+1)
                    line.set_x2(line_b,bar_index+1)
                line.set_y1(line_t,hi)
                line.set_y2(line_t,hi)
                line.set_y1(line_b,lo)
                line.set_y2(line_b,lo)
                if show_labelX and not na(line_label)
                    label.set_y(line_label, hi)
            int(na)




//*****************************//
// Daylight Savings Time Flags //
//*****************************//

int previousSunday = dayofmonth - dayofweek + 1
bool nyDST = false
bool ukDST = false
bool sydDST = false
 
if month < 3 or month > 11
    nyDST := false
    ukDST := false
    sydDST := true
else if month > 4 and month < 10
    nyDST := true
    ukDST := true
    sydDST := false
else if month == 3
    nyDST := previousSunday >= 8
    ukDST := previousSunday >= 24
    sydDST := true
else if month == 4
    nyDST := true
    ukDST := true
    sydDST := previousSunday <= 0
else if month == 10
    nyDST := true
    ukDST := previousSunday <= 24
    sydDST := previousSunday >= 0
else // month == 11
    nyDST := previousSunday <= 0
    ukDST := false
    sydDST := true
    



_sess1gmt = ukDST ? 'GMT+1' : 'GMT+0'
if ukDST
    draw_open_range(sess1Time,sess1col,show_or1,'GMT+1')
else
    draw_open_range(sess1Time,sess1col,show_or1,'GMT+0')
draw_session_hilo(sess1Time, show_rectangle1, show_label1, sess1colLabel, sess1Label, _sess1gmt)

_sess2gmt = nyDST ? 'GMT+1' : 'GMT+0'
if nyDST
    draw_open_range(sess2Time,sess2col,show_or2,'GMT+1')
else
    draw_open_range(sess2Time,sess2col,show_or2,'GMT+0')
draw_session_hilo(sess2Time, show_rectangle2, show_label2, sess2colLabel, sess2Label, _sess2gmt)

// Tokyo
draw_open_range(sess3Time,sess3col,show_or3,'GMT+0')
draw_session_hilo(sess3Time, show_rectangle3, show_label3, sess3colLabel, sess3Label, 'GMT+0')

// Hong Kong
draw_open_range(sess4Time,sess4col,show_or4,'GMT+0')
draw_session_hilo(sess4Time, show_rectangle4, show_label4, sess4colLabel, sess4Label, 'GMT+0')

_sess5gmt = sydDST ? 'GMT+1' : 'GMT+0'
if sydDST
    draw_open_range(sess5Time,sess5col,show_or5,'GMT+1')
else
    draw_open_range(sess5Time,sess5col,show_or5,'GMT+0')
draw_session_hilo(sess5Time, show_rectangle5, show_label5, sess5colLabel, sess5Label, _sess5gmt)


_sess7gmt = nyDST ? 'GMT+1' : 'GMT+0'
if nyDST
    draw_open_range(sess7Time,sess7col,show_or7,'GMT+1')
else
    draw_open_range(sess7Time,sess7col,show_or7,'GMT+0')
draw_session_hilo(sess7Time, show_rectangle7, show_label7, sess7colLabel, sess7Label, _sess7gmt)





//////////////////////////////////////////////////
////QQE MOD
/////////////////////////////////////////////////

qqe_gorup = "██████████ QQE ██████████"
RSI_Period = input(6, title='RSI Length', group=qqe_gorup)
SF = input(5, title='RSI Smoothing', group=qqe_gorup)
QQE = input(3, title='Fast QQE Factor', group=qqe_gorup)
ThreshHold = input(3, title='Thresh-hold', group=qqe_gorup)
//

srcqqe = input(close, title='RSI Source', group=qqe_gorup)
//

//
Wilders_Period = RSI_Period * 2 - 1


Rsi = ta.rsi(srcqqe, RSI_Period)
RsiMa = ta.ema(Rsi, SF)
AtrRsi = math.abs(RsiMa[1] - RsiMa)
MaAtrRsi = ta.ema(AtrRsi, Wilders_Period)
dar = ta.ema(MaAtrRsi, Wilders_Period) * QQE

longband = 0.0
shortband = 0.0
trend = 0

DeltaFastAtrRsi = dar
RSIndex = RsiMa
newshortband = RSIndex + DeltaFastAtrRsi
newlongband = RSIndex - DeltaFastAtrRsi
longband := RSIndex[1] > longband[1] and RSIndex > longband[1] ? math.max(longband[1], newlongband) : newlongband
shortband := RSIndex[1] < shortband[1] and RSIndex < shortband[1] ? math.min(shortband[1], newshortband) : newshortband
cross_1 = ta.cross(longband[1], RSIndex)
trend := ta.cross(RSIndex, shortband[1]) ? 1 : cross_1 ? -1 : nz(trend[1], 1)
FastAtrRsiTL = trend == 1 ? longband : shortband


length = input.int(50, minval=1, title='Bollinger Length', group=qqe_gorup)
multqqe = input.float(0.35, minval=0.001, maxval=5, step=0.1, title='BB Multiplier', group=qqe_gorup)
basis = ta.sma(FastAtrRsiTL - 50, length)
dev = multqqe * ta.stdev(FastAtrRsiTL - 50, length)
upperqqe = basis + dev
lowerqqe = basis - dev
color_bar = RsiMa - 50 > upperqqe ? #00c3ff : RsiMa - 50 < lowerqqe ? #ff0062 : color.gray


//
// Zero cross
QQEzlong = 0
QQEzlong := nz(QQEzlong[1])
QQEzshort = 0
QQEzshort := nz(QQEzshort[1])
QQEzlong := RSIndex >= 50 ? QQEzlong + 1 : 0
QQEzshort := RSIndex < 50 ? QQEzshort + 1 : 0
//  


////////////////////////////////////////////////////////////////

RSI_Period2 = input(6, title='RSI Length', group=qqe_gorup)
SF2 = input(5, title='RSI Smoothing', group=qqe_gorup)
QQE2 = input(1.61, title='Fast QQE2 Factor', group=qqe_gorup)
ThreshHold2 = input(3, title='Thresh-hold', group=qqe_gorup)

src2 = input(close, title='RSI Source', group=qqe_gorup)
//

//
isqqeabove = false
isqqebelow = false
if respectqqe or leadingindicator == 'QQE Mod'
    Wilders_Period2 = RSI_Period2 * 2 - 1


    Rsi2 = ta.rsi(src2, RSI_Period2)
    RsiMa2 = ta.ema(Rsi2, SF2)
    AtrRsi2 = math.abs(RsiMa2[1] - RsiMa2)
    MaAtrRsi2 = ta.ema(AtrRsi2, Wilders_Period2)
    dar2 = ta.ema(MaAtrRsi2, Wilders_Period2) * QQE2
    longband2 = 0.0
    shortband2 = 0.0
    trend2 = 0

    DeltaFastAtrRsi2 = dar2
    RSIndex2 = RsiMa2
    newshortband2 = RSIndex2 + DeltaFastAtrRsi2
    newlongband2 = RSIndex2 - DeltaFastAtrRsi2
    longband2 := RSIndex2[1] > longband2[1] and RSIndex2 > longband2[1] ? math.max(longband2[1], newlongband2) : newlongband2
    shortband2 := RSIndex2[1] < shortband2[1] and RSIndex2 < shortband2[1] ? math.min(shortband2[1], newshortband2) : newshortband2
    cross_2 = ta.cross(longband2[1], RSIndex2)
    trend2 := ta.cross(RSIndex2, shortband2[1]) ? 1 : cross_2 ? -1 : nz(trend2[1], 1)
    FastAtrRsi2TL = trend2 == 1 ? longband2 : shortband2


    //
    // Zero cross
    QQE2zlong = 0
    QQE2zlong := nz(QQE2zlong[1])
    QQE2zshort = 0
    QQE2zshort := nz(QQE2zshort[1])
    QQE2zlong := RSIndex2 >= 50 ? QQE2zlong + 1 : 0
    QQE2zshort := RSIndex2 < 50 ? QQE2zshort + 1 : 0
    //
    qqeline = FastAtrRsi2TL - 50
    // hcolor2 = RsiMa2 - 50 > ThreshHold2 ? color.silver : RsiMa2 - 50 < 0 - ThreshHold2 ? color.silver : na


    Greenbar1 = RsiMa2 - 50 > ThreshHold2
    Greenbar2 = RsiMa - 50 > upperqqe

    Redbar1 = RsiMa2 - 50 < 0 - ThreshHold2
    Redbar2 = RsiMa - 50 < lowerqqe

    // isqqebarabove = Greenbar1 and Greenbar2
    // isqqebarbelow = Redbar1 and Redbar2


    if qqetype == 'Line'
        isqqeabove := qqeline>0
        isqqebelow := qqeline<0
    else if qqetype == 'Bar'
        isqqeabove := RsiMa2 - 50 > 0 and (Greenbar1 and Greenbar2)
        isqqebelow := RsiMa2 - 50 < 0 and (Redbar1 and Redbar2)
    else if qqetype == 'Line & Bar'
        isqqeabove := RsiMa2 - 50 > 0 and (Greenbar1 and Greenbar2) and qqeline>0
        isqqebelow := RsiMa2 - 50 < 0 and (Redbar1 and Redbar2) and qqeline<0


/////////////////////////////////////////////////
/////////////// Volume Up/Down
////////////////////////////////////////////////
vgroup = "██████████ Up/Down Volume ██████████"
lowerTimeframeTooltip = "The indicator scans lower timeframe data to approximate Up/Down volume. By default, the timeframe is chosen automatically. These inputs override this with a custom timeframe.\n\nHigher timeframes provide more historical data, but the data will be less precise."
useCustomTimeframeInput = input.bool(false, "Use custom timeframe", tooltip = lowerTimeframeTooltip,group=vgroup)
lowerTimeframeInput = input.timeframe("1", "Timeframe",group=vgroup)

upAndDownVolume() =>
    posVol = 0.0
    negVol = 0.0
    
    switch
        close >  open     => posVol += volume
        close <  open     => negVol -= volume
        close >= close[1] => posVol += volume
        close <  close[1] => negVol -= volume

    [posVol, negVol]

var lowerTimeframe = switch
    useCustomTimeframeInput => lowerTimeframeInput
    timeframe.isintraday    => "1"
    timeframe.isdaily       => "5"
    => "60"

longvol = false
shortvol = false

if respectvol
    // Modify the timeframe argument in the security call
    timeframeForSecurity = useCustomTimeframeInput ? lowerTimeframeInput : timeframe.period

    [upVolumeArray, downVolumeArray] = request.security_lower_tf(syminfo.tickerid, timeframeForSecurity, upAndDownVolume())



    SMALength = input(20, title="SMA Length",group=vgroup)
    volume_ma = ta.sma(volume, SMALength)

    volume_abovema_signal = volume > volume_ma

    upVolume = array.sum(upVolumeArray)
    downVolume = array.sum(downVolumeArray)
    delta = upVolume + downVolume
    prevdelta = delta[1]

    if volumetype == 'Delta'
        longvol := delta > 0 and delta > delta[1]
        shortvol := delta < 0 and delta < delta[1]
    else if volumetype == 'volume above MA'
        longvol := volume_abovema_signal
        shortvol := volume_abovema_signal
    else
        longvol := upVolume > upVolume[1]
        shortvol := downVolume < downVolume[1]

var cumVol = 0.
cumVol += nz(volume)
if barstate.islast and cumVol == 0
    runtime.error("The data vendor doesn't provide volume data for this symbol.")




respectemavalue = ta.ema(src, respectemaperiod)
isaboverespectema = close > respectemavalue
isbelowrespectema = close < respectemavalue



sarup = out < close
sardown = out > close

//==============================================================================
// SMART MONEY CONCEPTS [LuxAlgo] - Integrated
//==============================================================================

smc_group = "██████████ Smart Money Concepts ██████████"
smc_mode = input.string("Present", "Mode", group=smc_group, options=["Historical", "Present"], tooltip="Historical shows all structure labels. Present shows only the latest — uses fewer labels.")
smc_style = input.string("Colored", "Style", group=smc_group, options=["Colored", "Monochrome"], tooltip="Colored uses distinct colors for bullish/bearish. Monochrome uses neutral tones.")
smc_show_internals = input.bool(true, "Show Internal Structure", group=smc_group, tooltip="Show internal BOS/CHoCH structure (shorter swing)")
smc_show_swing = input.bool(true, "Show Swing Structure", group=smc_group, tooltip="Show swing BOS/CHoCH structure (larger swings)")
smc_show_ob = input.bool(true, "Order Blocks", group=smc_group, inline='smcob', tooltip="Show order block zones where institutions likely entered")
smc_ob_size = input.int(5, "", minval=1, maxval=20, group=smc_group, inline='smcob', tooltip="Number of order blocks to display")
smc_show_fvg = input.bool(false, "Fair Value Gaps", group=smc_group, tooltip="Show imbalance zones (3-candle gaps). Resource-heavy — disable if hitting label limits.")
smc_show_hl = input.bool(true, "Strong/Weak High/Low", group=smc_group, tooltip="Show strong/weak high/low lines — identifies likely reversal levels")
smc_show_eq = input.bool(true, "Equal High/Low", group=smc_group, tooltip="Show equal highs/lows — liquidity pools that price tends to revisit")
smc_int_bull_color = input.color(#089981, "Internal Bullish", group=smc_group, inline='smcib')
smc_int_bear_color = input.color(#F23645, "Internal Bearish", group=smc_group, inline='smcibb')
smc_sw_bull_color = input.color(#089981, "Swing Bullish", group=smc_group, inline='smcsb')
smc_sw_bear_color = input.color(#F23645, "Swing Bearish", group=smc_group, inline='smcsbb')

// SMC Constants
SMC_BULLISH = +1
SMC_BEARISH = -1
SMC_BULLISH_LEG = 1
SMC_BEARISH_LEG = 0
SMC_GREEN = #089981
SMC_RED = #F23645
SMC_MONO_BULL = #b2b5be
SMC_MONO_BEAR = #5d606b

// SMC UDTs
type smc_pivot
    float currentLevel
    float lastLevel
    bool crossed
    int barTime = time
    int barIndex = bar_index

type smc_trend
    int bias

type smc_orderBlock
    float barHigh
    float barLow
    int barTime
    int bias

type smc_fairValueGap
    float top
    float bottom
    int bias
    box topBox
    box bottomBox

type smc_trailingExtremes
    float top
    float bottom
    int barTime
    int barIndex
    int lastTopTime
    int lastBottomTime

type smc_equalDisplay
    line l_ine = na
    label l_abel = na

type smc_alerts
    bool swingBullishBOS = false
    bool swingBearishBOS = false
    bool swingBullishCHoCH = false
    bool swingBearishCHoCH = false
    bool internalBullishBOS = false
    bool internalBearishBOS = false
    bool internalBullishCHoCH = false
    bool internalBearishCHoCH = false
    bool equalHighs = false
    bool equalLows = false

// SMC Variables
var smc_pivot smc_swingHigh = smc_pivot.new(na, na, false)
var smc_pivot smc_swingLow = smc_pivot.new(na, na, false)
var smc_pivot smc_internalHigh = smc_pivot.new(na, na, false)
var smc_pivot smc_internalLow = smc_pivot.new(na, na, false)
var smc_pivot smc_equalHigh = smc_pivot.new(na, na, false)
var smc_pivot smc_equalLow = smc_pivot.new(na, na, false)
var smc_trend smc_swingTrend = smc_trend.new(0)
var smc_trend smc_internalTrend = smc_trend.new(0)
var smc_equalDisplay smc_eqHighDisplay = smc_equalDisplay.new()
var smc_equalDisplay smc_eqLowDisplay = smc_equalDisplay.new()
var array<smc_fairValueGap> smc_fvgs = array.new<smc_fairValueGap>()
var array<smc_orderBlock> smc_swingOBs = array.new<smc_orderBlock>()
var array<smc_orderBlock> smc_internalOBs = array.new<smc_orderBlock>()
var array<box> smc_swingOBBoxes = array.new<box>()
var array<box> smc_internalOBBoxes = array.new<box>()
var smc_trailingExtremes smc_trailing = smc_trailingExtremes.new()
var smc_alerts smc_currentAlerts = smc_alerts.new()
smc_currentAlerts := smc_alerts.new()

// SMC HTF confluence (request.security must execute every bar)
smc_htf_bias = request.security(syminfo.tickerid, smc_htf_timeframe, smc_swingTrend.bias)
bool smc_htf_conf_long = smc_htf_bias == SMC_BULLISH
bool smc_htf_conf_short = smc_htf_bias == SMC_BEARISH

// SMC Colors
smc_swingBullColor = smc_style == "Monochrome" ? SMC_MONO_BULL : smc_sw_bull_color
smc_swingBearColor = smc_style == "Monochrome" ? SMC_MONO_BEAR : smc_sw_bear_color
smc_intBullColor = smc_style == "Monochrome" ? SMC_MONO_BULL : smc_int_bull_color
smc_intBearColor = smc_style == "Monochrome" ? SMC_MONO_BEAR : smc_int_bear_color

// SMC Volatility
smc_atr = ta.atr(200)
smc_volMeasure = ta.cum(ta.tr) / bar_index

// SMC Parsed Highs/Lows
smc_highVolBar = (high - low) >= (2 * smc_volMeasure)
smc_parsedHigh = smc_highVolBar ? low : high
smc_parsedLow = smc_highVolBar ? high : low

// SMC Mitigation Sources
smc_bearMitSrc = close
smc_bullMitSrc = close

// SMC Functions
smc_leg(int size) =>
    var leg = 0
    newLegHigh = high[size] > ta.highest(size)
    newLegLow = low[size] < ta.lowest(size)
    if newLegHigh
        leg := SMC_BEARISH_LEG
    else if newLegLow
        leg := SMC_BULLISH_LEG
    leg

smc_drawLabel(int labelTime, float labelPrice, string tag, color labelColor, string labelStyle) =>
    var label l_abel = na
    if smc_mode == "Present"
        l_abel.delete()
    l_abel := label.new(chart.point.new(labelTime, na, labelPrice), tag, xloc.bar_time, color=color(na), textcolor=labelColor, style=labelStyle, size=size.small)

smc_drawStructure(smc_pivot p_ivot, string tag, color structureColor, string lineStyle, string labelStyle, string labelSize) =>
    var line l_ine = line.new(na, na, na, na, xloc=xloc.bar_time)
    var label l_abel = label.new(na, na)
    if smc_mode == "Present"
        l_ine.delete()
        l_abel.delete()
    l_ine := line.new(chart.point.new(p_ivot.barTime, na, p_ivot.currentLevel), chart.point.new(time, na, p_ivot.currentLevel), xloc.bar_time, color=structureColor, style=lineStyle)
    l_abel := label.new(chart.point.new(na, math.round(0.5 * (p_ivot.barIndex + bar_index)), p_ivot.currentLevel), tag, xloc.bar_index, color=color(na), textcolor=structureColor, style=labelStyle, size=labelSize)

smc_drawEqualHL(smc_pivot p_ivot, float level, int size, bool equalHigh) =>
    smc_equalDisplay e_Display = equalHigh ? smc_eqHighDisplay : smc_eqLowDisplay
    string tag = equalHigh ? 'EQH' : 'EQL'
    color eqColor = equalHigh ? smc_swingBearColor : smc_swingBullColor
    string lStyle = equalHigh ? label.style_label_down : label.style_label_up
    if smc_mode == "Present"
        line.delete(e_Display.l_ine)
        label.delete(e_Display.l_abel)
    e_Display.l_ine := line.new(chart.point.new(p_ivot.barTime, na, p_ivot.currentLevel), chart.point.new(time[size], na, level), xloc=xloc.bar_time, color=eqColor, style=line.style_dotted)
    e_Display.l_abel := label.new(chart.point.new(na, math.round(0.5 * (p_ivot.barIndex + bar_index - size)), level), tag, xloc.bar_index, color=color(na), textcolor=eqColor, style=lStyle, size=size.tiny)

smc_storeOB(smc_pivot p_ivot, bool internal, int bias) =>
    if (not internal and smc_show_ob) or (internal and smc_show_ob)
        float ph = bias == SMC_BEARISH ? smc_parsedHigh : smc_parsedLow
        int ob_lookback = bar_index - p_ivot.barIndex
        float ob_high = ta.highest(high, ob_lookback)
        float ob_low = ta.lowest(low, ob_lookback)
        float best = bias == SMC_BEARISH ? ob_high : ob_low
        smc_orderBlock ob = smc_orderBlock.new(high, low, time, bias)
        array<smc_orderBlock> obs = internal ? smc_internalOBs : smc_swingOBs
        if obs.size() >= 50
            obs.pop()
        obs.unshift(ob)

bool smc_ob_bull_mitigated = false
bool smc_ob_bear_mitigated = false

smc_deleteOBs(bool internal = false) =>
    array<smc_orderBlock> obs = internal ? smc_internalOBs : smc_swingOBs
    bool _bear_mit = false
    bool _bull_mit = false
    for [index, eachOB] in obs
        bool crossed = false
        if (smc_bearMitSrc > eachOB.barHigh) and (eachOB.bias == SMC_BEARISH)
            crossed := true
            _bear_mit := true
        else if (smc_bullMitSrc < eachOB.barLow) and (eachOB.bias == SMC_BULLISH)
            crossed := true
            _bull_mit := true
        if crossed
            obs.remove(index)
    [_bear_mit, _bull_mit]

smc_drawOBs(bool internal = false) =>
    array<smc_orderBlock> obs = internal ? smc_internalOBs : smc_swingOBs
    array<box> b_oxes = internal ? smc_internalOBBoxes : smc_swingOBBoxes
    maxOBs = smc_ob_size
    if obs.size() > 0
        parsed = obs.slice(0, math.min(maxOBs, obs.size()))
        for [index, eachOB] in parsed
            obColor = internal ? (eachOB.bias == SMC_BEARISH ? color.new(#f77c80, 80) : color.new(#3179f5, 80)) : (eachOB.bias == SMC_BEARISH ? color.new(#b22833, 80) : color.new(#1848cc, 80))
            if index < b_oxes.size()
                box b = b_oxes.get(index)
                b.set_top_left_point(chart.point.new(eachOB.barTime, na, eachOB.barHigh))
                b.set_bottom_right_point(chart.point.new(last_bar_time, na, eachOB.barLow))
                b.set_bgcolor(obColor)

smc_deleteFVGs() =>
    for [index, eachFVG] in smc_fvgs
        if (low < eachFVG.bottom and eachFVG.bias == SMC_BULLISH) or (high > eachFVG.top and eachFVG.bias == SMC_BEARISH)
            eachFVG.topBox.delete()
            eachFVG.bottomBox.delete()
            smc_fvgs.remove(index)

smc_drawFVGs() =>
    bullishFVG = low > high[2] and close > high[2]
    bearishFVG = high < low[2] and close < low[2]
    fvgBullColor = smc_style == "Monochrome" ? color.new(SMC_MONO_BULL, 70) : color.new(#00ff68, 70)
    fvgBearColor = smc_style == "Monochrome" ? color.new(SMC_MONO_BEAR, 70) : color.new(#ff0008, 70)
    if bullishFVG
        smc_fvgs.unshift(smc_fairValueGap.new(low, high[2], SMC_BULLISH, box.new(bar_index - 1, low, bar_index, math.avg(low, high[2]), border_color=fvgBullColor, bgcolor=fvgBullColor), box.new(bar_index - 1, math.avg(low, high[2]), bar_index, high[2], border_color=fvgBullColor, bgcolor=fvgBullColor)))
    if bearishFVG
        smc_fvgs.unshift(smc_fairValueGap.new(high, low[2], SMC_BEARISH, box.new(bar_index - 1, high, bar_index, math.avg(high, low[2]), border_color=fvgBearColor, bgcolor=fvgBearColor), box.new(bar_index - 1, math.avg(high, low[2]), bar_index, low[2], border_color=fvgBearColor, bgcolor=fvgBearColor)))

smc_getStructure(int size, bool equalHL = false, bool internal = false) =>
    currentLeg = smc_leg(size)
    newPivot = ta.change(currentLeg) != 0
    pivotLow = ta.change(currentLeg) == +1
    pivotHigh = ta.change(currentLeg) == -1

    if newPivot
        if pivotLow
            smc_pivot p_ivot = equalHL ? smc_equalLow : internal ? smc_internalLow : smc_swingLow
            if equalHL and math.abs(p_ivot.currentLevel - low[size]) < 0.1 * smc_atr
                smc_drawEqualHL(p_ivot, low[size], size, false)
                smc_currentAlerts.equalLows := true
            p_ivot.lastLevel := p_ivot.currentLevel
            p_ivot.currentLevel := low[size]
            p_ivot.crossed := false
            p_ivot.barTime := time[size]
            p_ivot.barIndex := bar_index[size]
            if not equalHL and not internal
                smc_trailing.bottom := p_ivot.currentLevel
                smc_trailing.barTime := p_ivot.barTime
                smc_trailing.barIndex := p_ivot.barIndex
                smc_trailing.lastBottomTime := p_ivot.barTime
        else
            smc_pivot p_ivot = equalHL ? smc_equalHigh : internal ? smc_internalHigh : smc_swingHigh
            if equalHL and math.abs(p_ivot.currentLevel - high[size]) < 0.1 * smc_atr
                smc_drawEqualHL(p_ivot, high[size], size, true)
                smc_currentAlerts.equalHighs := true
            p_ivot.lastLevel := p_ivot.currentLevel
            p_ivot.currentLevel := high[size]
            p_ivot.crossed := false
            p_ivot.barTime := time[size]
            p_ivot.barIndex := bar_index[size]
            if not equalHL and not internal
                smc_trailing.top := p_ivot.currentLevel
                smc_trailing.barTime := p_ivot.barTime
                smc_trailing.barIndex := p_ivot.barIndex
                smc_trailing.lastTopTime := p_ivot.barTime

smc_displayStructure(bool internal = false) =>
    smc_pivot p_ivot = internal ? smc_internalHigh : smc_swingHigh
    smc_trend t_rend = internal ? smc_internalTrend : smc_swingTrend
    lineStyle = internal ? line.style_dashed : line.style_solid
    labelSize = internal ? size.tiny : size.small
    bullColor = internal ? smc_intBullColor : smc_swingBullColor

    if ta.crossover(close, p_ivot.currentLevel) and not p_ivot.crossed
        string tag = t_rend.bias == SMC_BEARISH ? "CHoCH" : "BOS"
        if internal
            smc_currentAlerts.internalBullishCHoCH := tag == "CHoCH"
            smc_currentAlerts.internalBullishBOS := tag == "BOS"
        else
            smc_currentAlerts.swingBullishCHoCH := tag == "CHoCH"
            smc_currentAlerts.swingBullishBOS := tag == "BOS"
        p_ivot.crossed := true
        t_rend.bias := SMC_BULLISH
        showCond = internal ? smc_show_internals : smc_show_swing
        if showCond
            smc_drawStructure(p_ivot, tag, bullColor, lineStyle, label.style_label_down, labelSize)
        if smc_show_ob
            smc_storeOB(p_ivot, internal, SMC_BULLISH)

    p_ivot := internal ? smc_internalLow : smc_swingLow
    bearColor = internal ? smc_intBearColor : smc_swingBearColor

    if ta.crossunder(close, p_ivot.currentLevel) and not p_ivot.crossed
        string tag = t_rend.bias == SMC_BULLISH ? "CHoCH" : "BOS"
        if internal
            smc_currentAlerts.internalBearishCHoCH := tag == "CHoCH"
            smc_currentAlerts.internalBearishBOS := tag == "BOS"
        else
            smc_currentAlerts.swingBearishCHoCH := tag == "CHoCH"
            smc_currentAlerts.swingBearishBOS := tag == "BOS"
        p_ivot.crossed := true
        t_rend.bias := SMC_BEARISH
        showCond = internal ? smc_show_internals : smc_show_swing
        if showCond
            smc_drawStructure(p_ivot, tag, bearColor, lineStyle, label.style_label_up, labelSize)
        if smc_show_ob
            smc_storeOB(p_ivot, internal, SMC_BEARISH)

// SMC Execution
bool smc_long = false
bool smc_short = false
bool smc_conf_long = false
bool smc_conf_short = false
bool fv_ob_conf_long = false
bool fv_ob_conf_short = false

if switch_smc or respectsmc or leadingindicator == "Smart Money Concepts"
    // Init OB boxes
    if barstate.isfirst
        if smc_show_ob
            for i = 1 to smc_ob_size
                smc_swingOBBoxes.push(box.new(na, na, na, na, xloc=xloc.bar_time, extend=extend.right))
                smc_internalOBBoxes.push(box.new(na, na, na, na, xloc=xloc.bar_time, extend=extend.right))

    // Update trailing
    if smc_show_hl
        smc_trailing.top := math.max(high, smc_trailing.top)
        smc_trailing.lastTopTime := smc_trailing.top == high ? time : smc_trailing.lastTopTime
        smc_trailing.bottom := math.min(low, smc_trailing.bottom)
        smc_trailing.lastBottomTime := smc_trailing.bottom == low ? time : smc_trailing.lastBottomTime

    // Structure detection
    smc_getStructure(50, false, false)
    smc_getStructure(5, false, true)
    if smc_show_eq
        smc_getStructure(3, true)

    // Display structure
    if smc_show_internals or smc_show_ob
        smc_displayStructure(true)
    if smc_show_swing or smc_show_hl
        smc_displayStructure()

    // Order blocks
    if smc_show_ob
        [_bm1, _bl1] = smc_deleteOBs(true)
        [_bm2, _bl2] = smc_deleteOBs(false)
        if _bm1 or _bm2
            smc_ob_bear_mitigated := true
        if _bl1 or _bl2
            smc_ob_bull_mitigated := true

    // FVGs
    if smc_show_fvg
        smc_deleteFVGs()
        smc_drawFVGs()

    // Draw OBs on last bar
    if barstate.islastconfirmedhistory or barstate.islast
        if smc_show_ob
            smc_drawOBs(true)
            smc_drawOBs()

    // FVG-OB Confluence Detection
    fv_ob_conf_long := false
    fv_ob_conf_short := false
    if smc_show_ob and smc_show_fvg
        for eachFVG in smc_fvgs
            for eachOB in smc_swingOBs
                // Check spatial overlap: OB top > FVG bottom AND OB bottom < FVG top
                if eachOB.barHigh > eachFVG.bottom and eachOB.barLow < eachFVG.top
                    // Bullish confluence: both FVG and OB are bullish
                    if eachFVG.bias == SMC_BULLISH and eachOB.bias == SMC_BULLISH
                        fv_ob_conf_long := true
                    // Bearish confluence: both FVG and OB are bearish
                    else if eachFVG.bias == SMC_BEARISH and eachOB.bias == SMC_BEARISH
                        fv_ob_conf_short := true

    // Draw Strong/Weak H/L
    if smc_show_hl and (barstate.islastconfirmedhistory or barstate.islast)
        var line smc_topLine = line.new(na, na, na, na, color=smc_swingBearColor, xloc=xloc.bar_time)
        var line smc_botLine = line.new(na, na, na, na, color=smc_swingBullColor, xloc=xloc.bar_time)
        var label smc_topLabel = label.new(na, na, color=color(na), textcolor=smc_swingBearColor, xloc=xloc.bar_time, style=label.style_label_down, size=size.tiny)
        var label smc_botLabel = label.new(na, na, color=color(na), textcolor=smc_swingBullColor, xloc=xloc.bar_time, style=label.style_label_up, size=size.tiny)
        rightTime = last_bar_time + 20 * (time - time[1])
        smc_topLine.set_first_point(chart.point.new(smc_trailing.lastTopTime, na, smc_trailing.top))
        smc_topLine.set_second_point(chart.point.new(rightTime, na, smc_trailing.top))
        smc_topLabel.set_point(chart.point.new(rightTime, na, smc_trailing.top))
        smc_topLabel.set_text(smc_swingTrend.bias == SMC_BEARISH ? 'Strong High' : 'Weak High')
        smc_botLine.set_first_point(chart.point.new(smc_trailing.lastBottomTime, na, smc_trailing.bottom))
        smc_botLine.set_second_point(chart.point.new(rightTime, na, smc_trailing.bottom))
        smc_botLabel.set_point(chart.point.new(rightTime, na, smc_trailing.bottom))
        smc_botLabel.set_text(smc_swingTrend.bias == SMC_BULLISH ? 'Strong Low' : 'Weak Low')

    // SMC signals
    // Leading: event-based (fire on trend change only)
    smc_trend_changed = smc_swingTrend.bias != nz((smc_swingTrend[1]).bias)
    smc_long := smc_swingTrend.bias == SMC_BULLISH and smc_trend_changed
    smc_short := smc_swingTrend.bias == SMC_BEARISH and smc_trend_changed
    // Confirmation: state-based (persistent bias)
    smc_conf_long := smc_swingTrend.bias == SMC_BULLISH
    smc_conf_short := smc_swingTrend.bias == SMC_BEARISH

//==============================================================================
// SMART MONEY BREAKOUT CHANNELS [AlgoAlpha] - Integrated
//==============================================================================

bc_group = "██████████ Breakout Channels ██████████"
bc_overlap = input.bool(false, "Nested Channels", group=bc_group, tooltip="Allow multiple channels to overlap. When disabled, only one channel at a time.")
bc_strong = input.bool(true, "Strong Closes Only", group=bc_group, tooltip="Breakouts only trigger when >50% of candle body is outside the channel. Reduces false signals from wicks.")
bc_norm_length = input.int(100, "Normalization Length", minval=1, group=bc_group, tooltip="Bars used for price normalization. Higher = more stable but less responsive.")
bc_box_length = input.int(14, "Box Detection Length", minval=1, group=bc_group, tooltip="Bars used to detect channel patterns. Lower = more channels but noisier.")
bc_show_vol = input.bool(true, "Show Volume Analysis", group=bc_group, tooltip="Display volume bars within channels")
bc_vol_mode = input.string("Comparison", "Volume Mode", options=["Volume", "Comparison", "Delta"], group=bc_group, tooltip="Volume: total volume bars. Comparison: up/down volume split. Delta: net volume delta.")
bc_vol_scale = input.float(0.5, "Volume Scale", minval=0.1, maxval=2.0, step=0.1, group=bc_group, tooltip="Height of volume bars relative to channel size")
bc_green = input.color(#00ffbb, "Bullish Colour", group=bc_group)
bc_red = input.color(#ff1100, "Bearish Colour", group=bc_group)

var array<box> bc_boxes = array.new_box()
var array<box> bc_boxes_u = array.new_box()
var array<box> bc_boxes_l = array.new_box()
var array<line> bc_centerLines = array.new<line>()

bool bc_bullishBreakout = false
bool bc_bearishBreakout = false
float bc_upbreak = 0.0
float bc_downbreak = 0.0

bc_canCreate(float tNew, float bNew) =>
    ok = true
    if bc_boxes.size() > 0
        for j = 0 to bc_boxes.size() - 1
            if (tNew > bc_boxes.get(j).get_bottom()) and (bNew < bc_boxes.get(j).get_top())
                ok := false
                break
    ok

bool bc_newChannel = false

if switch_bc or respectbc or leadingindicator == "Breakout Channels"
    bc_lowestLow = ta.lowest(low, bc_norm_length)
    bc_highestHigh = ta.highest(high, bc_norm_length)
    bc_normPrice = (close - bc_lowestLow) / (bc_highestHigh - bc_lowestLow)
    bc_vol = ta.stdev(bc_normPrice, 14)
    bc_upper = (ta.highestbars(bc_vol, bc_box_length + 1) + bc_box_length) / bc_box_length
    bc_lower = (ta.lowestbars(bc_vol, bc_box_length + 1) + bc_box_length) / bc_box_length
    bc_duration = math.max(nz(ta.barssince(ta.crossover(bc_lower, bc_upper))), 1)
    bc_h = ta.highest(bc_duration)
    bc_l = ta.lowest(bc_duration)
    bc_vola = ta.atr(bc_box_length) / 2

    if ta.crossover(bc_upper, bc_lower) and bc_duration > 10
        if bc_overlap or bc_canCreate(bc_h, bc_l)
            bc_newChannel := true
            bc_boxes.unshift(box.new(bar_index - bc_duration, bc_h, bar_index, bc_l, bgcolor=color.new(chart.fg_color, 90), border_color=na))
            bc_boxes_u.unshift(box.new(bar_index - bc_duration, bc_h, bar_index, bc_h - bc_vola, bgcolor=color.new(bc_red, 70), border_color=na))
            bc_boxes_l.unshift(box.new(bar_index - bc_duration, bc_l + bc_vola, bar_index, bc_l, bgcolor=color.new(bc_green, 70), border_color=na))
            float centerY = (bc_h + bc_l) / 2
            bc_centerLines.unshift(line.new(bar_index - bc_duration, centerY, bar_index, centerY, color=color.new(chart.fg_color, 50), width=1, style=line.style_dashed))

    // Cap max channels to preserve box budget for SMC
    while bc_boxes.size() > 30
        bc_boxes.pop()
        bc_boxes_u.pop()
        bc_boxes_l.pop()
        bc_centerLines.pop()

    if bc_boxes.size() > 0
        for i = bc_boxes.size() - 1 to 0
            if ((bc_strong ? math.avg(close, open) : close) > bc_boxes.get(i).get_top())
                bc_upbreak := bc_boxes.get(i).get_bottom()
                bc_boxes.remove(i)
                bc_boxes_u.remove(i)
                bc_boxes_l.remove(i)
                bc_centerLines.remove(i)
                bc_bullishBreakout := true
            else if ((bc_strong ? math.avg(close, open) : close) < bc_boxes.get(i).get_bottom())
                bc_downbreak := bc_boxes.get(i).get_top()
                bc_boxes.remove(i)
                bc_boxes_u.remove(i)
                bc_boxes_l.remove(i)
                bc_centerLines.remove(i)
                bc_bearishBreakout := true
            else
                bc_boxes.get(i).set_right(bar_index)
                bc_boxes_u.get(i).set_right(bar_index)
                bc_boxes_l.get(i).set_right(bar_index)
                bc_centerLines.get(i).set_x2(bar_index)

plotshape(bc_upbreak != 0 ? bc_upbreak : na, "BC Bullish Breakout", shape.labelup, location.absolute, bc_green, text="▲", textcolor=chart.fg_color, size=size.tiny)
plotshape(bc_downbreak != 0 ? bc_downbreak : na, "BC Bearish Breakout", shape.labeldown, location.absolute, bc_red, text="▼", textcolor=chart.fg_color, size=size.tiny)

//==============================================================================
// WILLIAMS VIX FIX - Integrated
//==============================================================================

vix_group = "██████████ Williams Vix Fix ██████████"
vix_pd = input.int(22, "Lookback Period", group=vix_group, tooltip="Period for highest close lookup. Standard is 22 (1 month of daily bars).")
vix_bbl = input.int(20, "Bollinger Band Length", group=vix_group, tooltip="Length for Bollinger Band calculation on Vix Fix values")
vix_mult = input.float(2.0, "BB StdDev Up", minval=1.0, maxval=5.0, group=vix_group, tooltip="Standard deviation multiplier for upper Bollinger Band")
vix_lb = input.int(50, "Percentile Lookback", group=vix_group, tooltip="Lookback period for percentile range calculation")
vix_ph = input.float(0.85, "Highest Percentile", group=vix_group, tooltip="Upper percentile threshold — Vix Fix above this signals potential market bottom")
vix_pl = input.float(1.01, "Lowest Percentile", group=vix_group, tooltip="Lower percentile threshold for range calculation")

bool vix_long = false
bool vix_short = false
bool vix_conf_long = false
bool vix_conf_short = false

if respectvix or leadingindicator == "Williams Vix Fix"
    vix_wvf = ((ta.highest(close, vix_pd) - low) / (ta.highest(close, vix_pd))) * 100
    vix_sDev = vix_mult * ta.stdev(vix_wvf, vix_bbl)
    vix_midLine = ta.sma(vix_wvf, vix_bbl)
    vix_upperBand = vix_midLine + vix_sDev
    vix_rangeHigh = (ta.highest(vix_wvf, vix_lb)) * vix_ph
    vix_rangeLow = (ta.lowest(vix_wvf, vix_lb)) * vix_pl

    vix_elevated = vix_wvf >= vix_upperBand or vix_wvf >= vix_rangeHigh
    vix_prev_elevated = vix_elevated[1] == true
    // Leading: event-based (trigger on transitions)
    vix_long := vix_elevated and not vix_prev_elevated
    vix_short := vix_prev_elevated and not vix_elevated
    // Confirmation: state-based (persistent bias)
    vix_conf_long := not vix_elevated
    vix_conf_short := vix_elevated

//==============================================================================
// SQUEEZE MOMENTUM [LazyBear] - Integrated
//==============================================================================

sqz_group = "██████████ Squeeze Momentum ██████████"
sqz_bb_len = input.int(20, "BB Length", group=sqz_group, tooltip="Bollinger Band length for squeeze detection")
sqz_bb_mult = input.float(2.0, "BB MultFactor", group=sqz_group, tooltip="Bollinger Band standard deviation multiplier")
sqz_kc_len = input.int(20, "KC Length", group=sqz_group, tooltip="Keltner Channel length for squeeze detection")
sqz_kc_mult = input.float(1.5, "KC MultFactor", group=sqz_group, tooltip="Keltner Channel ATR multiplier")
sqz_true_range = input.bool(true, "Use TrueRange (KC)", group=sqz_group, tooltip="Use True Range instead of simple high-low for Keltner Channel")

bool sqz_long = false
bool sqz_short = false
bool sqz_conf_long = false
bool sqz_conf_short = false
bool sqz_active_conf_long = false
bool sqz_active_conf_short = false
bool sqz_active = false
float sqz_val = na

bool sqzOn = false
bool sqzOff = false

if respectsqz or leadingindicator == "Squeeze Momentum" or switch_squeeze
    sqz_basis = ta.sma(close, sqz_bb_len)
    sqz_dev = sqz_bb_mult * ta.stdev(close, sqz_bb_len)
    sqz_upperBB = sqz_basis + sqz_dev
    sqz_lowerBB = sqz_basis - sqz_dev

    sqz_ma = ta.sma(close, sqz_kc_len)
    sqz_range = sqz_true_range ? ta.tr : (high - low)
    sqz_rangema = ta.sma(sqz_range, sqz_kc_len)
    sqz_upperKC = sqz_ma + sqz_rangema * sqz_kc_mult
    sqz_lowerKC = sqz_ma - sqz_rangema * sqz_kc_mult

    sqzOn := (sqz_lowerBB > sqz_lowerKC) and (sqz_upperBB < sqz_upperKC)
    sqzOff := (sqz_lowerBB < sqz_lowerKC) and (sqz_upperBB > sqz_upperKC)

    sqz_val := ta.linreg(close - math.avg(math.avg(ta.highest(high, sqz_kc_len), ta.lowest(low, sqz_kc_len)), ta.sma(close, sqz_kc_len)), sqz_kc_len, 0)

    sqz_active := sqzOn
    // Leading: event-based (squeeze release with momentum)
    sqz_long := sqzOff and sqz_val > 0
    sqz_short := sqzOff and sqz_val < 0
    // Confirmation: state-based (momentum direction)
    sqz_conf_long := sqz_val > 0
    sqz_conf_short := sqz_val < 0
    // Squeeze active filter: not squeezing = safe to trade (trending market)
    sqz_active_conf_long := not sqzOn
    sqz_active_conf_short := not sqzOn

// Squeeze dots on chart (must be at global scope)
plotshape(eff_switch_squeeze and sqzOn ? low : na, "Squeeze Active", shape.circle, location.belowbar, color.new(color.orange, 50), size=size.tiny)
plotshape(eff_switch_squeeze and sqzOff and sqz_val > 0 ? low : na, "Squeeze Release Bull", shape.circle, location.belowbar, color.green, size=size.tiny)
plotshape(eff_switch_squeeze and sqzOff and sqz_val < 0 ? low : na, "Squeeze Release Bear", shape.circle, location.belowbar, color.red, size=size.tiny)



longCond = false
shortCond = false


