sc53 = not eff_respectsession or session_conf_short
sc54 = not eff_respectfv_ob or fv_ob_conf_short
sc55 = not eff_respecttm or tm_conf_short

longCond := leadinglongcond and lc1 and lc2 and lc3 and lc4 and lc5 and lc6 and lc7 and lc8 and lc9 and lc10 and lc11 and lc12 and lc13 and lc14 and lc15 and lc16 and lc17 and lc18 and lc19 and lc20 and lc21 and lc22 and lc23 and lc24 and lc25 and lc26 and lc27 and lc28 and lc29 and lc30 and lc31 and lc32 and lc33 and lc34 and lc35 and lc36 and lc37 and lc38 and lc39 and lc40 and lc41 and lc42 and lc43 and lc44 and lc45 and lc46 and lc47 and lc48 and lc49 and lc50 and lc51 and lc52 and lc53 and lc54 and lc55

shortCond := leadingshortcond and sc1 and sc2 and sc3 and sc4 and sc5 and sc6 and sc7 and sc8 and sc9 and sc10 and sc11 and sc12 and sc13 and sc14 and sc15 and sc16 and sc17 and sc18 and sc19 and sc20 and sc21 and sc22 and sc23 and sc24 and sc25 and sc26 and sc27 and sc28 and sc29 and sc30 and sc31 and sc32 and sc33 and sc34 and sc35 and sc36 and sc37 and sc38 and sc39 and sc40 and sc41 and sc42 and sc43 and sc44 and sc45 and sc46 and sc47 and sc48 and sc49 and sc50 and sc51 and sc52 and sc53 and sc54 and sc55

// Signal scoring mode: count passing confirmation filters
int long_score = 0
int short_score = 0
if use_signal_scoring
    long_score += (eff_respectrf and uprf) ? 1 : 0
    long_score += (eff_respectadx and adxupcondition) ? 1 : 0
    long_score += (eff_respecttsi and tsi_long) ? 1 : 0
    long_score += (eff_respecthacolt and hacolt_long) ? 1 : 0
    long_score += (eff_respectmd and md_long) ? 1 : 0
    long_score += (eff_respecttdfi and tdfi_long) ? 1 : 0
    long_score += (eff_respectdpo and dpo_long) ? 1 : 0
